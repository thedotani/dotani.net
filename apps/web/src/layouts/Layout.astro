---
import '../styles/global.css'
import { getSiteSettings } from '../lib/sanity'
import { themeStyle, THEME_STORAGE_KEY, resolveInitialScheme, mergeInlineStyles } from '../lib/theme'
import { layoutStyle } from '../lib/layout'
import MobileNav from '../components/MobileNav.astro'
import ThemeToggle from '../components/ThemeToggle.astro'
import SocialLinks from '../components/SocialLinks.astro'
import Footer from '../components/Footer.astro'
import BackToTop from '../components/BackToTop.astro'
import SiteMotion from '../components/SiteMotion.astro'
import { isNavActive } from '../lib/navigation'
import { resolveMenuItems } from '../lib/menus'
import { resolveSocialLinks } from '../lib/socials'

interface Props {
  title: string
  description?: string
  includeTurnstile?: boolean
}

const { title, description, includeTurnstile = false } = Astro.props
const siteSettings = await getSiteSettings()
const htmlThemeStyle = mergeInlineStyles(
  themeStyle(siteSettings?.theme),
  layoutStyle(siteSettings?.layoutSettings, siteSettings?.theme?.containerWidth),
)
const pathname = Astro.url.pathname
const headerLogo =
  siteSettings?.brand?.logos?.main || siteSettings?.header?.logo
const hasLogo = Boolean(headerLogo?.asset?.url)
const siteTitle =
  siteSettings?.brand?.siteTitle || siteSettings?.header?.title || 'dotani.net'
const logoAlt =
  siteSettings?.brand?.logoAlt || siteSettings?.header?.logoAlt || siteTitle
const initialScheme = resolveInitialScheme(siteSettings?.theme?.darkModeDefault)
const universalMenus = siteSettings?.menus?.items
const menuItems = resolveMenuItems(universalMenus, siteSettings?.header?.menuItems, 'header')
const mobileMenuItems = resolveMenuItems(
  universalMenus,
  siteSettings?.mobileMenu?.menuItems?.length
    ? siteSettings.mobileMenu.menuItems
    : siteSettings?.header?.menuItems,
  'mobileMenu',
)
const mobileMenuFooterItems = resolveMenuItems(universalMenus, undefined, 'mobileMenuFooter')
const headerCta = siteSettings?.header?.headerCta
const allSocialLinks =
  siteSettings?.socials?.links || siteSettings?.footer?.socialLinks || []
const headerSocialLinks = resolveSocialLinks(
  allSocialLinks,
  'header',
  siteSettings?.header?.showSocials !== 'hide',
)
const mobileSocialLinks = resolveSocialLinks(
  allSocialLinks,
  'mobileMenu',
  siteSettings?.mobileMenu?.showSocials !== 'hide',
)
---

<!doctype html>
<html lang="en" data-theme={initialScheme} style={htmlThemeStyle}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline define:vars={{ THEME_STORAGE_KEY, initialScheme }}>
      (function () {
        try {
          const stored = localStorage.getItem(THEME_STORAGE_KEY)
          const scheme = stored === 'dark' || stored === 'light' ? stored : initialScheme
          document.documentElement.setAttribute('data-theme', scheme)
        } catch (_) {
          document.documentElement.setAttribute('data-theme', initialScheme)
        }
      })()
    </script>
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    {/* Open Graph / social sharing meta tags */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={`${Astro.url.origin}/og-image.jpg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={siteTitle} />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={`${Astro.url.origin}/og-image.jpg`} />

    {/* Canonical URL */}
    <link rel="canonical" href={Astro.url.href} />

    {includeTurnstile && (
      <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer />
    )}
  </head>

  <body>
    <header class="site-header">
      <div class="section-container">
        <div class="site-header-bar">
          <div class="site-header-brand">
            {mobileMenuItems.length > 0 && (
              <MobileNav menuItems={mobileMenuItems} pathname={pathname} variant="toggle" />
            )}

            <a href="/" class="site-logo">
              {hasLogo && (
                <img
                  src={headerLogo.asset.url}
                  alt={logoAlt}
                  class="site-logo-image"
                />
              )}
              {!hasLogo && (
                <span class="site-logo-text">
                  {siteTitle}
                </span>
              )}
            </a>
          </div>

          {menuItems.length > 0 && (
            <nav class="site-nav-desktop" aria-label="Main navigation">
              {menuItems.map((item: any) => (
                <a
                  href={item.url}
                  class:list={[
                    'nav-link',
                    { 'nav-link-active': isNavActive(pathname, item.url) },
                  ]}
                >
                  {item.label}
                </a>
              ))}
            </nav>
          )}

          <div class="site-header-utilities">
            {headerSocialLinks.length > 0 && (
              <SocialLinks links={headerSocialLinks} variant="header" />
            )}
            {headerCta?.label && (
              <a href={headerCta.url} class="btn btn-primary btn-header-cta">
                {headerCta.label}
              </a>
            )}
            <ThemeToggle />
          </div>
        </div>
      </div>
    </header>

    {mobileMenuItems.length > 0 && (
      <MobileNav
        menuItems={mobileMenuItems}
        pathname={pathname}
        socialLinks={mobileSocialLinks}
        menuFooterItems={mobileMenuFooterItems}
        menuFooterText={
          mobileMenuFooterItems.length === 0
            ? siteSettings?.mobileMenu?.footerText
            : undefined
        }
        variant="overlay"
      />
    )}

    <slot />

    <Footer
      footer={siteSettings?.footer}
      brand={siteSettings?.brand}
      header={siteSettings?.header}
      menus={siteSettings?.menus}
      socialLinks={resolveSocialLinks(allSocialLinks, 'footer', true)}
    />
    <BackToTop />
    <SiteMotion />
  </body>
</html>
---
import Layout from '../../layouts/Layout.astro'
import PortableText from '../../components/PortableText.astro'
import { getCaseStudyBySlug, getAllCaseStudies } from '../../lib/sanity'

export async function getStaticPaths() {
  const caseStudies = await getAllCaseStudies()
  return (
    caseStudies?.map((study: any) => ({
      params: { slug: study.slug?.current },
      props: { study },
    })) || []
  )
}

const { slug } = Astro.params
const study = Astro.props.study || (await getCaseStudyBySlug(slug as string))

if (!study) {
  return Astro.redirect('/404')
}

const primaryPortfolio = study.relatedPortfolio?.[0]
const metaItems = [
  study.client && { label: 'Client', value: study.client },
  study.industry && { label: 'Industry', value: study.industry },
  study.year && { label: 'Year', value: String(study.year) },
  study.role && { label: 'Role', value: study.role },
  study.scope && { label: 'Scope', value: study.scope },
  study.duration && { label: 'Duration', value: study.duration },
].filter(Boolean)
---

<Layout
  title={study.seo?.title || `${study.title} — Case Study`}
  description={study.seo?.description || study.summary?.[0]?.children?.[0]?.text}
>
  <section class="detail-hero detail-hero--compact" data-card-spotlight>
    <div class="detail-orb detail-orb--primary" style="width:20rem;height:20rem;top:-2rem;right:-2rem;"></div>
    <div class="detail-orb detail-orb--accent" style="width:16rem;height:16rem;bottom:-1rem;left:2%;"></div>
    <div class="detail-orb detail-orb--purple" style="width:12rem;height:12rem;top:40%;left:-2rem;"></div>
    <div class="section-container">
      <nav class="detail-breadcrumb" data-motion="fade" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
        <a href="/portfolio">Portfolio</a>
        {primaryPortfolio && (
          <>
            <span class="breadcrumb-sep" aria-hidden="true">/</span>
            <a href={`/portfolio/${primaryPortfolio.slug?.current}`}>{primaryPortfolio.title}</a>
          </>
        )}
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
        <span class="breadcrumb-current">Case Study</span>
      </nav>
    </div>
  </section>

  <div class="section-container detail-layout detail-layout--meta-end">
    <aside class="detail-aside" data-motion="scale">
      <div class="detail-post-header">
        <p class="section-eyebrow mb-2">Case Study</p>
        <h1 class="section-heading-hero mb-4">{study.title}</h1>
        {study.client && (
          <p class="text-lg text-accent font-semibold mb-3">{study.client}</p>
        )}
        {primaryPortfolio?.shortResult && (
          <p class="section-tagline text-lg">{primaryPortfolio.shortResult}</p>
        )}
      </div>
      {metaItems.length > 0 && (
        <div class="flex flex-col gap-2 mt-5">
          {metaItems.map((item: any) => (
            <div class="detail-meta-strip">
              <p class="detail-meta-label">{item.label}</p>
              <p class="detail-meta-value truncate">{item.value}</p>
            </div>
          ))}
        </div>
      )}
      {study.tools && study.tools.length > 0 && (
        <div class="flex flex-col gap-2 mt-5">
          <p class="text-[0.6875rem] font-semibold uppercase tracking-wider text-muted mb-2">Tools</p>
          <div class="flex flex-wrap gap-1.5">
            {study.tools.map((tool: string) => (
              <span class="detail-tag !text-[0.65rem] !px-2.5 !py-1">{tool}</span>
            ))}
          </div>
        </div>
      )}
    </aside>

    <div class="detail-main detail-stack" data-motion-stagger>
    {study.challenge && (
      <section class="detail-block" data-motion="rise">
        <div class="detail-block__head">
          <div class="detail-section-icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
          </div>
          <h2 class="detail-block__title">The Challenge</h2>
        </div>
        <PortableText value={study.challenge} class="text-muted leading-relaxed space-y-5" />
      </section>
    )}

    {study.approach && (
      <section class="detail-block" data-motion="rise" style="--motion-delay: 120ms">
        <div class="detail-block__head">
          <div class="detail-section-icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
          </div>
          <h2 class="detail-block__title">Strategic Approach</h2>
        </div>
        <PortableText value={study.approach} class="text-muted leading-relaxed space-y-5" />
      </section>
    )}

    {study.process && study.process.length > 0 && (
      <section class="detail-block" data-motion="rise" style="--motion-delay: 200ms">
        <div class="detail-block__head">
          <div class="detail-section-icon" style="border-color: color-mix(in srgb, rgb(245 158 11) 15%, transparent); background: linear-gradient(145deg, color-mix(in srgb, rgb(245 158 11) 10%, transparent), transparent);">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: rgb(245 158 11);"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h2 class="detail-block__title">Execution Process</h2>
        </div>
        <div class="detail-timeline">
          {study.process
            .slice()
            .sort((a: any, b: any) => (a.number ?? 0) - (b.number ?? 0))
            .map((step: any) => (
              <div class="detail-timeline-step">
                <div class="flex items-start gap-4">
                  <div class="detail-timeline-number">{step.number}</div>
                  <div class="flex-1 min-w-0">
                    <h3 class="font-display text-lg font-bold text-heading mb-2">{step.title}</h3>
                    {step.description && <p class="text-sm sm:text-base text-muted leading-relaxed">{step.description}</p>}
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </section>
    )}

    {study.visuals && study.visuals.length > 0 && (
      <section class="detail-block" data-motion="rise" style="--motion-delay: 280ms">
        <div class="detail-block__head">
          <div class="detail-section-icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <h2 class="detail-block__title">Visual Showcase</h2>
        </div>
        <div class="detail-gallery">
          {study.visuals.map((image: any) => (
            <div class="detail-gallery-item">
              <img
                src={image?.asset?.url || '/images/placeholder-portfolio.svg'}
                alt={study.title}
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </section>
    )}

    {study.results && study.results.length > 0 && (
      <section class="detail-block" data-motion="rise" style="--motion-delay: 320ms">
        <div class="detail-block__head">
          <div class="detail-section-icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
          </div>
          <h2 class="detail-block__title">Results & Impact</h2>
        </div>
        <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
          {study.results.map((result: any) => (
            <div class="detail-metric" data-card-spotlight>
              <div class="detail-metric-value">{result.value}</div>
              <div class="detail-metric-label">{result.label}</div>
            </div>
          ))}
        </div>
      </section>
    )}

    {study.outputs && study.outputs.length > 0 && (
      <section class="detail-block" data-motion="rise" style="--motion-delay: 380ms">
        <div class="detail-block__head">
          <div class="detail-section-icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h2 class="detail-block__title">Key Outputs</h2>
        </div>
        <div class="space-y-1">
          {study.outputs.map((output: string) => (
            <div class="detail-check-item">
              <div class="detail-check-icon">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-muted leading-relaxed">{output}</span>
            </div>
          ))}
        </div>
      </section>
    )}

    {study.impact && (
      <section data-motion="rise" style="--motion-delay: 420ms">
        <div class="detail-section detail-section--impact" data-card-spotlight>
          <div class="flex items-center gap-3 mb-6">
            <div class="detail-section-icon">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
            </div>
            <h2 class="font-display text-2xl font-bold text-heading">Impact</h2>
          </div>
          <PortableText value={study.impact} class="text-muted leading-relaxed space-y-5" />
        </div>
      </section>
    )}

    {study.lessons && (
      <section class="detail-block" data-motion="rise" style="--motion-delay: 480ms">
        <div class="detail-block__head">
          <div class="detail-section-icon">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
          </div>
          <h2 class="detail-block__title">Lessons & Insights</h2>
        </div>
        <PortableText value={study.lessons} class="text-muted leading-relaxed space-y-5" />
      </section>
    )}

    <div class="detail-cta" data-card-spotlight>
      <h2 class="font-display text-2xl sm:text-3xl font-bold mb-4">Ready to create something remarkable?</h2>
      <p class="text-white/80 mb-8 max-w-2xl mx-auto">
        Transform your vision into measurable results. Let's discuss how strategy meets execution.
      </p>
      <div class="flex flex-row flex-wrap items-center justify-center gap-3 sm:gap-4">
        <a href="/booking" class="btn bg-white text-gray-900 hover:bg-white/90">
          Schedule Strategy Call
        </a>
        <a href="/contact" class="btn border-2 border-white/30 text-white hover:bg-white/10">
          Get in Touch
        </a>
      </div>
    </div>
  </div>
</Layout>

---
import Layout from '../layouts/Layout.astro'
import HeroSection from '../components/sections/HeroSection.astro'
import StatsSection from '../components/sections/StatsSection.astro'
import ServicesSection from '../components/sections/ServicesSection.astro'
import PortfolioSection from '../components/sections/PortfolioSection.astro'
import WhyMeSection from '../components/sections/WhyMeSection.astro'
import TestimonialsSection from '../components/sections/TestimonialsSection.astro'
import FinalCtaSection from '../components/sections/FinalCtaSection.astro'
import ContactSection from '../components/sections/ContactSection.astro'
import BookingSection from '../components/sections/BookingSection.astro'
import { getHomePage, getAllServices, getAllPortfolioItems, getAllTestimonials } from '../lib/sanity'

const [page, services, portfolioItems, testimonials] = await Promise.all([
  getHomePage(),
  getAllServices(),
  getAllPortfolioItems(),
  getAllTestimonials(),
])

const sections = page?.sections ?? []
const hasVisibleSections = sections.some((section: any) => section?.visible !== false)
const showFallback = !page || !hasVisibleSections
---

<Layout
  title={page?.seo?.title || page?.title || 'Home'}
  description={page?.seo?.description}
  includeTurnstile
>
  <main>
    {showFallback && (
      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
        <p class="text-sm font-medium text-primary uppercase tracking-wider mb-4">dotani.net</p>
        <h1 class="text-4xl md:text-5xl font-bold text-heading mb-6">
          {page?.title || 'Welcome'}
        </h1>
        <p class="text-xl text-muted max-w-2xl mx-auto mb-8">
          {page?.excerpt || 'Content is being prepared. Add a home page and site settings in Sanity Studio to populate this site.'}
        </p>
        {import.meta.env.DEV && (
          <a
            href="http://localhost:3333"
            class="inline-block px-6 py-3 bg-primary text-white rounded-lg hover:bg-primary/90 transition-colors"
          >
            Open Sanity Studio
          </a>
        )}
      </section>
    )}
    {sections.map((section: any) => {
      if (section.visible === false) return null

      const Component = (() => {
        switch (section._type) {
          case 'heroSection':
            return HeroSection
          case 'statsSection':
            return StatsSection
          case 'servicesSection':
            return ServicesSection
          case 'portfolioSection':
            return PortfolioSection
          case 'whyMeSection':
            return WhyMeSection
          case 'testimonialsSection':
            return TestimonialsSection
          case 'finalCtaSection':
            return FinalCtaSection
          case 'contactSection':
            return ContactSection
          case 'bookingSection':
            return BookingSection
          default:
            return null
        }
      })()

      if (!Component) return null

      const props: any = { section }
      if (section._type === 'servicesSection') {
        props.services = section.displayMode === 'auto' ? services : section.manualServices || []
      }
      if (section._type === 'portfolioSection') {
        props.portfolioItems = section.displayMode === 'auto' ? portfolioItems : section.manualItems || []
      }
      if (section._type === 'testimonialsSection') {
        props.testimonials = section.displayMode === 'auto' ? testimonials : []
      }

      return (
        <div id={section.sectionId || undefined}>
          <Component {...props} />
        </div>
      )
    })}
  </main>
</Layout>
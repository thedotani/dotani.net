---
import Layout from '../../layouts/Layout.astro'
import { getAllPortfolioItems } from '../../lib/sanity'

const portfolioItems = await getAllPortfolioItems()
---

<Layout title="Portfolio" description="Our work portfolio">
  <main class="section-container py-20">
      <h1 class="section-heading mb-4">Our Work</h1>
      <p class="section-tagline mb-12 max-w-2xl">Selected projects across strategy, content, campaigns, and digital presence.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {portfolioItems?.map((item: any) => (
          <article class="group card-surface overflow-hidden p-0 hover:translate-y-0">
            <div class="aspect-video overflow-hidden bg-border/30">
              <img
                src={item.thumbnail?.asset?.url || '/images/placeholder-portfolio.svg'}
                alt={item.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
          <div class="p-6">
            <span class="text-xs font-semibold text-primary uppercase tracking-wider">
              {item.category}
            </span>
              <h2 class="font-display text-xl font-semibold text-heading mt-2 mb-2">
              {item.title}
            </h2>
            {item.shortResult && (
              <p class="text-sm text-muted mb-4">
                {item.shortResult}
              </p>
            )}
            {item.role && (
              <p class="text-sm text-accent">
                Role: {item.role}
              </p>
            )}
            <a
              href={`/portfolio/${item.slug?.current}`}
              class="mt-4 inline-block text-sm font-medium text-primary hover:underline"
            >
              View Project →
            </a>
          </div>
        </article>
      ))}
    </div>
  </main>
</Layout>
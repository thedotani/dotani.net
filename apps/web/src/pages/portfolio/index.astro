---
import { getAllPortfolioItems } from '../../lib/sanity'

const portfolioItems = await getAllPortfolioItems()
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Portfolio</title>
    <meta name="description" content="Our work portfolio" />
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  </head>

  <body class="bg-bg text-text min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h1 class="text-4xl font-bold text-heading mb-12">Our Work</h1>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {portfolioItems?.map((item: any) => (
          <article class="group bg-card border border-border rounded-xl overflow-hidden hover:shadow-lg transition-shadow">
            {item.thumbnail && (
              <div class="aspect-video overflow-hidden">
                <img
                  src={item.thumbnail?.asset?.url || '/placeholder.png'}
                  alt={item.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                />
              </div>
            )}
            <div class="p-6">
              <span class="text-xs font-semibold text-primary uppercase tracking-wider">
                {item.category}
              </span>
              <h2 class="text-xl font-semibold text-heading mt-2 mb-2">
                {item.title}
              </h2>
              {item.shortResult && (
                <p class="text-sm text-muted mb-4">
                  {item.shortResult}
                </p>
              )}
              {item.role && (
                <p class="text-sm text-accent">
                  Role: {item.role}
                </p>
              )}
              <a
                href={`/portfolio/${item.slug?.current}`}
                class="mt-4 inline-block text-sm font-medium text-primary hover:underline"
              >
                View Project →
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </body>
</html>

<style>
  .text-primary { color: var(--primary-color, #3b82f6); }
  .text-heading { color: var(--heading-color, #1f2937); }
  .text-muted { color: var(--muted-color, #6b7280); }
  .text-accent { color: var(--accent-color, #f59e0b); }
  .bg-card { background-color: var(--card-bg, #ffffff); }
  .border-border { border-color: var(--border-color, #e5e7eb); }
</style>
---
import Layout from '../../layouts/Layout.astro'
import PortableText from '../../components/PortableText.astro'
import { getPortfolioItemBySlug, getAllPortfolioItems } from '../../lib/sanity'

export async function getStaticPaths() {
  const portfolioItems = await getAllPortfolioItems()
  return portfolioItems?.map((item: any) => ({
    params: { slug: item.slug?.current },
    props: { item },
  })) || []
}

const { slug } = Astro.params
const item = Astro.props.item || await getPortfolioItemBySlug(slug as string)

if (!item) {
  return Astro.redirect('/404')
}
---

<Layout
  title={`${item.title} - Portfolio`}
  description={item.shortResult}
>
  <main class="detail-page">
    <section class="detail-hero detail-hero--compact">
      <div class="detail-orb detail-orb--primary" style="width:20rem;height:20rem;top:-2rem;right:-2rem;"></div>
      <div class="detail-orb detail-orb--accent" style="width:16rem;height:16rem;bottom:-1rem;left:5%;"></div>
      <div class="section-container">
        <nav class="detail-breadcrumb" data-motion="fade">
          <a href="/portfolio">Portfolio</a>
          <span class="breadcrumb-sep" aria-hidden="true">/</span>
          <span class="breadcrumb-current">{item.title}</span>
        </nav>
      </div>
    </section>

    <div class="section-container detail-layout detail-layout--meta-end">
      <aside class="detail-aside" data-motion="scale">
        <div class="detail-post-header">
          {item.category && <span class="tag-pill mb-3">{item.category}</span>}
          {item.year && <span class="text-sm text-muted font-medium">{item.year}</span>}
          <h1 class="section-heading-hero mt-2 mb-4">{item.title}</h1>
          {item.shortResult && (
            <p class="section-tagline text-lg">{item.shortResult}</p>
          )}
        </div>
        {item.client && (
          <div class="detail-meta-strip" data-card-spotlight>
            <p class="detail-meta-label">Client</p>
            <p class="detail-meta-value">{item.client}</p>
          </div>
        )}
        {item.role && (
          <div class="detail-meta-strip" data-card-spotlight>
            <p class="detail-meta-label">Role</p>
            <p class="detail-meta-value">{item.role}</p>
          </div>
        )}
        {item.caseStudy?.slug?.current && (
          <a href={`/case-studies/${item.caseStudy.slug.current}`} class="link-chip w-full justify-center mt-auto">
            Read Case Study
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        )}
      </aside>

      <div class="detail-main detail-stack" data-motion-stagger>
        {item.description && (
          <section class="detail-block">
            <PortableText
              value={item.description}
              class="text-muted text-base sm:text-lg leading-relaxed"
            />
          </section>
        )}

        {item.metrics && item.metrics.length > 0 && (
          <section class="detail-block" data-motion="rise" style="--motion-delay: 120ms">
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
              {item.metrics.map((metric: any) => (
                <div class="detail-metric" data-card-spotlight>
                  <div class="detail-metric-value">{metric.value}</div>
                  <div class="detail-metric-label">{metric.label}</div>
                </div>
              ))}
            </div>
          </section>
        )}

        {item.projectSummary && (
          <section class="detail-block" data-motion="rise" style="--motion-delay: 200ms">
            <PortableText value={item.projectSummary} class="text-muted leading-relaxed space-y-5" />
          </section>
        )}

        {item.keyPoints && item.keyPoints.length > 0 && (
          <section class="detail-block" data-motion="rise" style="--motion-delay: 280ms">
            <div class="space-y-1">
              {item.keyPoints.map((point: string) => (
                <div class="detail-check-item">
                  <div class="detail-check-icon">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <span class="text-muted leading-relaxed">{point}</span>
                </div>
              ))}
            </div>
          </section>
        )}

        {item.gallery && item.gallery.length > 0 && (
          <section class="detail-block" data-motion="rise" style="--motion-delay: 320ms">
            <div class="detail-gallery">
              {item.gallery.map((image: any) => (
                <div class="detail-gallery-item">
                  <img
                    src={image?.asset?.url || '/images/placeholder-portfolio.svg'}
                    alt={item.title}
                    loading="lazy"
                  />
                </div>
              ))}
            </div>
          </section>
        )}

        {item.tags && item.tags.length > 0 && (
          <section class="detail-block" data-motion="rise" style="--motion-delay: 400ms">
            <div class="detail-tags">
              {item.tags.map((tag: string) => (
                <span class="detail-tag">{tag}</span>
              ))}
            </div>
          </section>
        )}
      </div>
    </div>
  </main>
</Layout>
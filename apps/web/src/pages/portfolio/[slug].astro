---
import Layout from '../../layouts/Layout.astro'
import chipStyles from '../../components/ui/LinkChip.module.css'
import tagStyles from '../../components/ui/Tag.module.css'
import PortableText from '../../components/PortableText.astro'
import { getPortfolioItemBySlug, getAllPortfolioItems } from '../../lib/sanity'

export async function getStaticPaths() {
  const portfolioItems = await getAllPortfolioItems()
  return portfolioItems?.map((item: any) => ({
    params: { slug: item.slug?.current },
    props: { item },
  })) || []
}

const { slug } = Astro.params
const item = Astro.props.item || await getPortfolioItemBySlug(slug as string)

if (!item) {
  return Astro.redirect('/404')
}
---

<Layout
  title={`${item.title} - Portfolio`}
  description={item.shortResult}
>
  <main class="detail-page">
    <section class="detail detail--compact">
      <div class="section-container">
        <nav class="detail-breadcrumb">
          <a href="/portfolio">Portfolio</a>
          <span class="breadcrumb-sep" aria-hidden="true">/</span>
          <span class="breadcrumb-current">{item.title}</span>
        </nav>
      </div>
    </section>

    <div class="section-container detail-layout detail-layout--meta-end">
      <aside class="detail-aside">
        <div class="detail-post-header">
          {item.category && <span class={tagStyles['tag-pill']}>{item.category}</span>}
          {item.year && <span>{item.year}</span>}
          <h1 class="section-heading">{item.title}</h1>
          {item.shortResult && (
            <p class="section-tagline">{item.shortResult}</p>
          )}
        </div>
        {item.client && (
          <div class="detail-meta-strip">
            <p class="detail-meta-label">Client</p>
            <p class="detail-meta-value">{item.client}</p>
          </div>
        )}
        {item.role && (
          <div class="detail-meta-strip">
            <p class="detail-meta-label">Role</p>
            <p class="detail-meta-value">{item.role}</p>
          </div>
        )}
        {item.caseStudy?.slug?.current && (
          <a href={`/case-studies/${item.caseStudy.slug.current}`} class={chipStyles['link-chip']}>
            Read Case Study
            <svg class="" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        )}
      </aside>

      <div class="detail-main detail-stack">
        {item.description && (
          <section class="detail-block">
            <PortableText value={item.description} />
          </section>
        )}

        {item.metrics && item.metrics.length > 0 && (
          <section class="detail-block">
            <div>
              {item.metrics.map((metric: any) => (
                <div class="detail-metric">
                  <div class="detail-metric-value">{metric.value}</div>
                  <div class="detail-metric-label">{metric.label}</div>
                </div>
              ))}
            </div>
          </section>
        )}

        {item.projectSummary && (
          <section class="detail-block">
            <PortableText value={item.projectSummary} />
          </section>
        )}

        {item.keyPoints && item.keyPoints.length > 0 && (
          <section class="detail-block">
            <div>
              {item.keyPoints.map((point: string) => (
                <div class="detail-check-item">
                  <div class="detail-check-icon">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <span>{point}</span>
                </div>
              ))}
            </div>
          </section>
        )}

        {item.gallery && item.gallery.length > 0 && (
          <section class="detail-block">
            <div class="detail-gallery">
              {item.gallery.map((image: any) => (
                <div class="detail-gallery-item">
                  <img
                    src={image?.asset?.url || '/images/placeholder-portfolio.svg'}
                    alt={item.title}
                    loading="lazy"
                  />
                </div>
              ))}
            </div>
          </section>
        )}

        {item.tags && item.tags.length > 0 && (
          <section class="detail-block">
            <div class="detail-tags">
              {item.tags.map((tag: string) => (
                <span class="detail-tag">{tag}</span>
              ))}
            </div>
          </section>
        )}
      </div>
    </div>
  </main>
</Layout>

---
import Layout from '../../layouts/Layout.astro'
import ServiceBadge from '../../components/ServiceBadge.astro'
import Button from '../../components/ui/Button.astro'
import PortableText from '../../components/PortableText.astro'
import { getServiceBySlug, getAllServices } from '../../lib/sanity'

export async function getStaticPaths() {
  const services = await getAllServices()
  return services?.map((service: any) => ({
    params: { slug: service.slug?.current },
    props: { service },
  })) || []
}

const { slug } = Astro.params
const service = Astro.props.service || await getServiceBySlug(slug as string)

if (!service) {
  return Astro.redirect('/404')
}
---

<Layout
  title={`${service.title} - Services`}
  description={service.shortDescription}
>
  <main class="detail-page">
    <section class="detail detail--compact">
      <div class="section-container">
        <nav class="detail-breadcrumb">
          <a href="/services">Services</a>
          <span class="breadcrumb-sep" aria-hidden="true">/</span>
          <span class="breadcrumb-current">{service.title}</span>
        </nav>
      </div>
    </section>

    <div class="section-container detail-layout">
      <aside class="detail-aside">
        <div class="detail-aside-header">
          <ServiceBadge icon={service.icon} size="lg" />
          <p class="section-eyebrow">Service</p>
        </div>
        <h1 class="section-heading">{service.title}</h1>
        {service.shortDescription && (
          <p class="section-tagline">{service.shortDescription}</p>
        )}
      </aside>

      <div class="detail-main detail-stack">
        {service.description && (
          <section class="detail-block">
            <div class="detail-block__head">
              <div class="detail-section-icon">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <h2 class="detail-block__title">Overview</h2>
            </div>
            <PortableText value={service.description} />
          </section>
        )}

        {service.features && service.features.length > 0 && (
          <section class="detail-block">
            <div class="detail-block__head">
              <div class="detail-section-icon">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"/></svg>
              </div>
              <h2 class="detail-block__title">Key Features</h2>
            </div>
            <div class="detail-feature-grid">
              {service.features.map((feature: any, i: number) => (
                <div class="detail-feature-item">
                  <div class="detail-feature-bullet">{String(i + 1).padStart(2, '0')}</div>
                  <span>{feature.text || feature}</span>
                </div>
              ))}
            </div>
          </section>
        )}

        {service.deliverables && service.deliverables.length > 0 && (
          <section class="detail-block">
            <div class="detail-block__head">
              <div class="detail-section-icon" style="border-color: color-mix(in srgb, rgb(16 185 129) 15%, transparent); background: linear-gradient(145deg, color-mix(in srgb, rgb(16 185 129) 10%, transparent), transparent);">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: rgb(16 185 129);"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <h2 class="detail-block__title">What You Get</h2>
            </div>
            <div>
              {service.deliverables.map((deliverable: string) => (
                <div class="detail-check-item">
                  <div class="detail-check-icon">
                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <span>{deliverable}</span>
                </div>
              ))}
            </div>
          </section>
        )}

        {(service.bestFor || service.timeframe) && (
          <div>
            {service.bestFor && (
              <div class="detail-info-strip">
                <p class="detail-info-label">Best For</p>
                <p class="detail-info-value">{service.bestFor}</p>
              </div>
            )}
            {service.timeframe && (
              <div class="detail-info-strip">
                <p class="detail-info-label">Timeframe</p>
                <p class="detail-info-value">{service.timeframe}</p>
              </div>
            )}
          </div>
        )}

        <div class="detail-cta">
          <h2>Ready to get started?</h2>
          <p>Let's discuss how {service.title.toLowerCase()} can transform your business.</p>
          <div>
            <Button variant="white" href="/booking">Book a Call</Button>
            <Button variant="outline" href="/contact" style="border-color: rgba(255,255,255,0.3); color: #fff;">Get in Touch</Button>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

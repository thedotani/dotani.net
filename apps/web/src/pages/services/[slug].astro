---
import Layout from '../../layouts/Layout.astro'
import ServiceBadge from '../../components/ServiceBadge.astro'
import PortableText from '../../components/PortableText.astro'
import { getServiceBySlug, getAllServices } from '../../lib/sanity'

export async function getStaticPaths() {
  const services = await getAllServices()
  return services?.map((service: any) => ({
    params: { slug: service.slug?.current },
    props: { service },
  })) || []
}

const { slug } = Astro.params
const service = Astro.props.service || await getServiceBySlug(slug as string)

if (!service) {
  return Astro.redirect('/404')
}
---

<Layout
  title={`${service.title} - Services`}
  description={service.shortDescription}
>
  <section class="page-hero relative">
    <div class="section-container">
      <!-- Creative split layout -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start">
        <div class="lg:col-span-5 lg:sticky lg:top-28">
          <a href="/services" class="breadcrumb mb-8 inline-block" data-motion="fade">← Back to Services</a>
          <div class="detail-hero-row" data-motion="scale">
            <ServiceBadge icon={service.icon} size="lg" class="mx-auto lg:mx-0 mb-6" />
            <div class="text-center lg:text-left">
              <p class="section-eyebrow mb-3">Service</p>
              <h1 class="section-heading-hero mb-4">{service.title}</h1>
              {service.shortDescription && (
                <p class="section-tagline max-w-md lg:max-w-none">{service.shortDescription}</p>
              )}
            </div>
          </div>
        </div>

        <div class="lg:col-span-7 space-y-8" data-motion-stagger>
          {service.description && (
            <article class="card-surface p-6 sm:p-8 relative overflow-hidden">
              <div class="absolute top-0 right-0 w-24 h-24 bg-primary/5 rounded-full blur-2xl -z-10"></div>
              <h2 class="font-display text-xl font-semibold text-heading mb-4 flex items-center gap-2">
                <span class="w-1.5 h-6 bg-primary rounded-full"></span>
                Overview
              </h2>
              <PortableText
                value={service.description}
                class="text-muted leading-relaxed text-base sm:text-lg"
              />
            </article>
          )}

          {service.features && service.features.length > 0 && (
            <article class="card-surface p-6 sm:p-8">
              <h2 class="font-display text-xl font-semibold text-heading mb-5">Key Features</h2>
              <ul class="space-y-3">
                {service.features.map((feature: any) => (
                  <li class="flex items-start gap-3 text-muted">
                    <span class="text-primary font-bold mt-0.5 shrink-0">▸</span>
                    <span>{feature.text || feature}</span>
                  </li>
                ))}
              </ul>
            </article>
          )}

          {service.deliverables && service.deliverables.length > 0 && (
            <article class="card-surface p-6 sm:p-8">
              <h2 class="font-display text-xl font-semibold text-heading mb-5">What You Get</h2>
              <ul class="space-y-3">
                {service.deliverables.map((deliverable: string) => (
                  <li class="flex items-start gap-3 text-muted">
                    <span class="text-accent font-bold mt-0.5 shrink-0">✓</span>
                    <span>{deliverable}</span>
                  </li>
                ))}
              </ul>
            </article>
          )}

          {(service.bestFor || service.timeframe) && (
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {service.bestFor && (
                <article class="card-surface p-5 text-center">
                  <p class="text-xs font-semibold uppercase tracking-wider text-primary mb-2">Best For</p>
                  <p class="text-heading font-medium">{service.bestFor}</p>
                </article>
              )}
              {service.timeframe && (
                <article class="card-surface p-5 text-center">
                  <p class="text-xs font-semibold uppercase tracking-wider text-accent mb-2">Timeframe</p>
                  <p class="text-heading font-medium">{service.timeframe}</p>
                </article>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
</Layout>
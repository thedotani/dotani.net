---
import PortableText from '../PortableText.astro'
import DynamicContent from '../DynamicContent.astro'
import ContactForm from '../ContactForm.astro'
import BookingBlock from '../BookingBlock.astro'
import ServiceBadge from '../ServiceBadge.astro'
import Button from '../ui/Button.astro'
import { sectionPaddingClasses } from '../../lib/sections'
import { blockSurfaceClass, blockInlineStyle } from '../../lib/blockStyle'
import { resolveSectionMeta, sectionShellClasses } from '../../lib/sectionStyle'

interface Props {
  section: any
  services?: any[]
  portfolioItems?: any[]
  testimonials?: any[]
  caseStudies?: any[]
  blogPosts?: any[]
}

const {
  section,
  services = [],
  portfolioItems = [],
  testimonials = [],
  caseStudies = [],
  blogPosts = [],
} = Astro.props

const {
  sectionId,
  badge,
  eyebrow,
  title,
  tagline,
  headerLink,
  contentMode = 'dynamic',
  dynamicContentType,
  customContent,
  buttons,
  image,
  imageSide = 'right',
  imageWidth = 33,
} = section

const meta = resolveSectionMeta(section)
const surfaceClass = blockSurfaceClass(section)
const inlineStyle = blockInlineStyle(section)
const shellClasses = sectionShellClasses(section, surfaceClass)
const paddingClasses = sectionPaddingClasses(section.paddingTop, section.paddingBottom)
const imageUrl = image?.asset?.url
const showImage = contentMode === 'custom' && Boolean(imageUrl)
const HeadingTag = meta.isHomeHero ? 'h1' : 'h2'

function resolveDynamicLimit(type?: string) {
  if (type === 'service') return 0
  if (sectionId === 'portfolio-grid' || sectionId === 'work-grid') return 0
  if (sectionId === 'services-list') return 0
  return 3
}
---

<section
  id={sectionId || undefined}
  class:list={[shellClasses, paddingClasses]}
  style={inlineStyle}
>
  {meta.isContact ? (
    <div class="block-layout">
      <ContactForm headline={title || 'Send a message'} supportingText={tagline} />
    </div>
  ) : meta.isBooking ? (
    <div class="block-layout">
      <BookingBlock headline={title || 'Prefer a call?'} supportingText={tagline} centered />
    </div>
  ) : (
    <div
      class:list={[
        'block-layout',
        showImage ? 'block-layout--split' : 'block-layout--stack',
        contentMode === 'dynamic' && 'block-layout--content-only',
        showImage && (imageSide === 'left' ? 'block-layout--image-left' : 'block-layout--image-right'),
        meta.isHomeHero && 'block-layout--hero',
        meta.isCenteredHeader && 'block-layout--centered-header',
        meta.isCentered && !showImage && 'block-layout--centered',
      ]}
      style={showImage ? `--image-width: ${imageWidth}%` : undefined}
    >
      {(badge || eyebrow || title || tagline) && (
        <div
          class:list={[
            'sec-header',
            meta.isHomeHero && 'copy',
          ]}
        >
          {badge && (
            <div>
              <ServiceBadge icon={badge} />
            </div>
          )}
          {eyebrow && (
            <p class:list={['section-eyebrow']}>
              {eyebrow}
            </p>
          )}
          {(title || tagline) && (
            <div class:list={['sec-title']}>
              {title && (
                <HeadingTag class:list={['section-heading']}>
                  {title}
                </HeadingTag>
              )}
              {tagline && <p class="section-tagline">{tagline}</p>}
            </div>
          )}
        </div>
      )}

      {showImage && (
        <div class="sec-image">
          <div>
            <img
              src={imageUrl}
              alt={title || 'Section image'}
              class="media-frame section-image-mobile"
              loading={meta.isHomeHero ? 'eager' : 'lazy'}
            />
          </div>
        </div>
      )}

      <div
        class:list={[
          'sec-content',
        ]}
      >
        {contentMode === 'custom' && customContent?.length > 0 && (
          <div>
            <PortableText value={customContent} />
          </div>
        )}

        {contentMode === 'dynamic' && dynamicContentType && (
          <DynamicContent
            type={dynamicContentType}
            services={services}
            portfolioItems={portfolioItems}
            testimonials={testimonials}
            caseStudies={caseStudies}
            blogPosts={blogPosts}
            limit={resolveDynamicLimit(dynamicContentType)}
            centered={meta.isCenteredHeader}
          />
        )}

        {contentMode === 'custom' && buttons?.length > 0 && (
          <div class="actions">
            {buttons.map((button: any) => (
              <Button
                href={button.url}
                variant={button.style || 'primary'}
                target={button.openInNewTab ? '_blank' : undefined}
                rel={button.openInNewTab ? 'noopener noreferrer' : undefined}
              >
                {button.label}
              </Button>
            ))}
          </div>
        )}
      </div>

      {contentMode === 'dynamic' && dynamicContentType && headerLink?.label && (
        <a href={headerLink.url} class="sec-link">
          {headerLink.label}
          <span aria-hidden="true">→</span>
        </a>
      )}
    </div>
  )}
</section>

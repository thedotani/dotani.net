---
interface Props {
  section: any
}

const {section} = Astro.props
const {
  headline,
  supportingText,
  buttons = [],
  layout = 'centered',
  centeredBackground = true,
  paddingTop = 'py-20',
  paddingBottom = 'py-20',
  backgroundColor,
} = section
---

<section
  class={`w-full ${paddingTop} ${paddingBottom}`}
  style={
    centeredBackground && layout === 'centered' && !backgroundColor
      ? `background-color: var(--color-primary, #3b82f6)`
      : backgroundColor
        ? `background-color: ${backgroundColor}`
        : undefined
  }
>
  <div class="section-container">
    {layout === 'centered' ? (
      <div class="text-center max-w-3xl mx-auto">
        {headline && (
          <h2 class={`section-heading mb-4 ${centeredBackground ? 'text-white' : ''}`}>
            {headline}
          </h2>
        )}
        {supportingText && (
          <p class={`section-tagline mb-8 ${centeredBackground ? 'text-white/85' : ''}`}>
            {supportingText}
          </p>
        )}
        {buttons && buttons.length > 0 && (
          <div class="flex flex-wrap justify-center gap-4">
            {buttons.map((button: any) => (
              <a
                href={button.url}
                class={`btn btn-${button.style || 'primary'} ${centeredBackground && button.style !== 'outline' ? 'bg-white text-heading hover:bg-white/90' : ''}`}
                target={button.openInNewTab ? '_blank' : undefined}
                rel={button.openInNewTab ? 'noopener noreferrer' : undefined}
              >
                {button.label}
              </a>
            ))}
          </div>
        )}
      </div>
    ) : (
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8">
        <div class="flex-1 max-w-2xl">
          {headline && (
            <h2 class="section-heading mb-4">
              {headline}
            </h2>
          )}
          {supportingText && (
            <p class="section-tagline">
              {supportingText}
            </p>
          )}
        </div>
        {buttons && buttons.length > 0 && (
          <div class="flex flex-wrap gap-4 md:justify-end">
            {buttons.map((button: any) => (
              <a
                href={button.url}
                class={`btn btn-${button.style || 'primary'}`}
                target={button.openInNewTab ? '_blank' : undefined}
                rel={button.openInNewTab ? 'noopener noreferrer' : undefined}
              >
                {button.label}
              </a>
            ))}
          </div>
        )}
      </div>
    )}
  </div>
</section>
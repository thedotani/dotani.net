---
interface Props {
  section: any
}

const {section} = Astro.props
const {
  headline,
  supportingText,
  calLink,
  buttonLabel = 'Book a Call',
  layout = 'centered',
  paddingTop = 'py-16',
  paddingBottom = 'py-20',
  backgroundColor,
} = section

const bookingBg = backgroundColor || '#1e293b'
---

<section
  class={`w-full ${paddingTop} ${paddingBottom}`}
  style={`background-color: ${bookingBg}`}
>
  <div class="section-container">
    {layout === 'centered' ? (
      <div class="text-center max-w-2xl mx-auto">
        {headline && (
          <h2 class="section-heading mb-4 text-white">
            {headline}
          </h2>
        )}
        {supportingText && (
          <p class="text-lg text-white/80 mb-8 leading-relaxed">
            {supportingText}
          </p>
        )}
        {(calLink || import.meta.env.PUBLIC_CALCOM_USERNAME) && (
          <a
            href={calLink || `https://cal.com/${import.meta.env.PUBLIC_CALCOM_USERNAME}`}
            target="_blank"
            rel="noopener noreferrer"
            class="btn bg-white text-heading hover:bg-white/90"
          >
            {buttonLabel}
          </a>
        )}
      </div>
    ) : (
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8">
        <div class="flex-1">
          {headline && (
            <h2 class="section-heading mb-4 text-white">
              {headline}
            </h2>
          )}
          {supportingText && (
            <p class="text-lg text-white/80 leading-relaxed">
              {supportingText}
            </p>
          )}
        </div>
        {(calLink || import.meta.env.PUBLIC_CALCOM_USERNAME) && (
          <a
            href={calLink || `https://cal.com/${import.meta.env.PUBLIC_CALCOM_USERNAME}`}
            target="_blank"
            rel="noopener noreferrer"
            class="btn bg-white text-heading hover:bg-white/90 shrink-0"
          >
            {buttonLabel}
          </a>
        )}
      </div>
    )}
  </div>
</section>
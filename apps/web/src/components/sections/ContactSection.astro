---
interface Props {
  section: any
}

const {section} = Astro.props
const {
  headline,
  supportingText,
  submitButtonText = 'Send Message',
  paddingTop = 'py-20',
  paddingBottom = 'py-20',
  backgroundColor,
} = section
---

<section
  id="contact"
  class={`w-full ${paddingTop} ${paddingBottom}`}
  style={backgroundColor ? `background-color: ${backgroundColor}` : undefined}
>
  <div class="section-container">
    <div class="max-w-2xl mx-auto">
      {headline && (
        <h2 class="section-heading mb-4 text-center">
          {headline}
        </h2>
      )}
      {supportingText && (
        <p class="section-tagline mb-10 text-center">
          {supportingText}
        </p>
      )}

      <form class="card-surface p-6 md:p-8 space-y-5 hover:translate-y-0 hover:shadow-sm" id="contact-form" action="/api/contact" method="POST">
        <div class="cf-turnstile" data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY}></div>

        <div>
          <label for="name" class="block text-sm font-medium text-heading mb-2">
            Name
          </label>
          <input type="text" id="name" name="name" required class="form-input" placeholder="Your name" />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-heading mb-2">
            Email
          </label>
          <input type="email" id="email" name="email" required class="form-input" placeholder="your@email.com" />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-heading mb-2">
            Message
          </label>
          <textarea
            id="message"
            name="message"
            rows={5}
            required
            class="form-input resize-none"
            placeholder="How can I help you?"
          ></textarea>
        </div>

        <button type="submit" class="btn btn-primary w-full">
          {submitButtonText}
        </button>
      </form>
    </div>
  </div>
</section>
---
import { sectionPaddingClasses } from '../../lib/sections'
import { blockSurfaceClass, blockInlineStyle } from '../../lib/blockStyle'
import { sectionShellClasses } from '../../lib/sectionStyle'

interface Props {
  section: any
}

const { section } = Astro.props
  const {
    displayType,
    statsSet,
    marqueeSet,
    speed = 30,
    skewY = 0,
    skewX = 0,
    height,
  } = section

const surfaceClass = blockSurfaceClass(section)
const inlineStyle = blockInlineStyle(section)
const shellClasses = sectionShellClasses(section, surfaceClass)
const paddingClasses = sectionPaddingClasses(section.paddingTop, section.paddingBottom)
const metrics = statsSet?.metrics ?? []
const marqueeItems = marqueeSet?.marqueeItems ?? []
const marqueeHeight = height?.value != null ? `${height.value}${height.unit || 'rem'}` : '4rem'
---

<section
  class:list={[shellClasses, paddingClasses]}
  style={inlineStyle}
>
  {displayType === 'stats' && metrics.length > 0 && (
    <div class="block-layout">
      <div class="stats-row">
        {metrics.map((item: any) => (
          <div class="stat-box">
            <div
              class="stat-value"
            >
              {item.value}
            </div>
<div class="stat-text">
              {item.description || item.name}
            </div>
            {item.note && <div>{item.note}</div>}
          </div>
        ))}
      </div>
    </div>
  )}

  {displayType === 'marquee' && marqueeItems.length > 0 && (
    <div class="block-layout">
      <div
        class="marquee-track"
        style={`--marquee-height: ${marqueeHeight}; --marquee-skew-y: ${skewY}deg; --marquee-skew-x: ${skewX}deg; --speed: ${speed}s;`}
      >
        <div class="marquee-track__inner">
          {[...marqueeItems, ...marqueeItems].map((item: any, index: number) => (
            <span class="marquee-track__item">
              <span class="marquee-track__content">
                {item.name}
                {item.note && <small class="marquee-track__note">{item.note}</small>}
              </span>
              {index < marqueeItems.length * 2 - 1 && (
                <span class="marquee-track__sep" aria-hidden="true">·</span>
              )}
            </span>
          ))}
        </div>
      </div>
    </div>
  )}
</section>

<style>
  .marquee-track {
    height: var(--marquee-height);
    transform: skewY(var(--marquee-skew-y)) skewX(var(--marquee-skew-x));
    transform-origin: left center;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 4%, black 96%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 4%, black 96%, transparent 100%);
  }

  .marquee-track__inner {
    display: flex;
    align-items: center;
    width: max-content;
    height: 100%;
    will-change: transform;
  }

  .marquee-track__item {
    display: inline-flex;
    align-items: center;
    margin-right: 3rem;
    font-size: clamp(2rem, 3vw, 2.35rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .marquee-track__content {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .marquee-track__note {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: none;
  }

  .marquee-track__sep {
    opacity: 0.35;
    margin-left: 1rem;
  }
</style>

<script defer src="/scripts/marquee.js"></script>

---
interface Props {
  section: any
}

const {section} = Astro.props
const {
  items = [],
  layout = 'inline',
  divider = false,
  paddingTop = 'py-12',
  paddingBottom = 'py-12',
  backgroundColor,
} = section
---

<section
  class={`w-full border-y border-border/80 ${paddingTop} ${paddingBottom}`}
  style={backgroundColor ? `background-color: ${backgroundColor}` : 'background-color: color-mix(in srgb, var(--color-bg) 92%, var(--color-primary) 8%)'}
>
  <div class="section-container">
    <div class={layout === 'grid' ? 'grid grid-cols-2 md:grid-cols-5 gap-6' : 'flex flex-wrap justify-between gap-8 md:gap-12'}>
      {items.map((item: any, index: number) => (
        <>
          <div class="text-center min-w-[7rem]">
            <div class="font-display text-3xl md:text-4xl font-bold text-primary mb-2">
              {item.number}
            </div>
            <div class="text-sm font-medium text-muted uppercase tracking-wider">
              {item.label}
            </div>
            {item.note && (
              <div class="text-xs text-muted mt-1">{item.note}</div>
            )}
          </div>
          {divider && index < items.length - 1 && layout === 'inline' && (
            <div class="hidden md:block w-px self-stretch bg-border"></div>
          )}
        </>
      ))}
    </div>
  </div>
</section>
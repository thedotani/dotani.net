---
interface Props {
  section: any
  testimonials?: any[]
}

const {section, testimonials = []} = Astro.props
const {
  sectionTitle,
  sectionTagline,
  cardStyle = 'standard',
  paddingTop = 'py-20',
  paddingBottom = 'py-20',
  backgroundColor,
} = section

const displayItems = testimonials.slice(0, section.limit || 3)
---

<section
  class={`w-full ${paddingTop} ${paddingBottom}`}
  style={backgroundColor ? `background-color: ${backgroundColor}` : undefined}
>
  <div class="section-container">
    <div class="text-center max-w-2xl mx-auto mb-12">
      {sectionTitle && (
        <h2 class="section-heading mb-4">
          {sectionTitle}
        </h2>
      )}
      {sectionTagline && (
        <p class="section-tagline">
          {sectionTagline}
        </p>
      )}
    </div>

    <div class={cardStyle === 'quote'
      ? 'max-w-3xl mx-auto'
      : cardStyle === 'minimal'
        ? 'grid grid-cols-1 md:grid-cols-2 gap-6'
        : 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6'
    }>
      {displayItems.map((item: any) => (
        <div class={`card-surface p-6 md:p-7 ${cardStyle === 'minimal' ? 'hover:translate-y-0 hover:shadow-sm' : ''}`}>
          {cardStyle === 'quote' && (
            <svg class="w-8 h-8 text-primary/80 mb-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M14.017 21v-7.03a8.007 8.007 0 0 0 5.432-7.432H9.574a4 4 0 0 1 0-8h10a4 4 0 0 1 4 4v10a4 4 0 0 1-4 4H9.574a4 4 0 0 1 0-8z"/>
            </svg>
          )}
          {item.quote && (
            <p class="text-muted leading-relaxed mb-5">
              "{typeof item.quote === 'string' ? item.quote : item.quote[0]?.children?.map((c: any) => c.text).join(' ')}"
            </p>
          )}
          {item.testimonial && (
            <p class="text-muted leading-relaxed mb-5">
              "{typeof item.testimonial === 'string' ? item.testimonial : item.testimonial[0]?.children?.map((c: any) => c.text).join(' ')}"
            </p>
          )}
          <div class="flex items-center gap-3">
            {item.authorAvatar?.asset?.url && (
              <img
                src={item.authorAvatar.asset.url}
                alt={item.authorName || 'Testimonial author'}
                class="w-11 h-11 rounded-full object-cover ring-2 ring-border"
              />
            )}
            <div>
              <p class="font-display font-semibold text-heading">
                {item.authorName || item.name}
              </p>
              {item.authorRole && (
                <p class="text-sm text-muted">{item.authorRole}</p>
              )}
              {item.role && (
                <p class="text-sm text-muted">{item.role}</p>
              )}
              {item.company && (
                <p class="text-xs text-accent mt-0.5">{item.company}</p>
              )}
            </div>
          </div>
          {item.rating && (
            <div class="flex mt-4 gap-0.5">
              {Array.from({length: 5}).map((_, i) => (
                <span class={`text-sm ${i < item.rating ? 'text-primary' : 'text-muted/40'}`}>★</span>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
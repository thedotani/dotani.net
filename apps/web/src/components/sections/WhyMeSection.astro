---
interface Props {
  section: any
}

const {section} = Astro.props
const {
  heading,
  description,
  bulletPoints = [],
  features = [],
  image,
  layout = 'contentLeft',
  paddingTop = 'py-20',
  paddingBottom = 'py-20',
  backgroundColor,
} = section
---

<section
  class={`w-full ${paddingTop} ${paddingBottom}`}
  style={backgroundColor ? `background-color: ${backgroundColor}` : undefined}
>
  <div class="section-container">
    <div class={`flex flex-col md:flex-row gap-12 lg:gap-16 items-center ${layout === 'imageLeft' ? 'md:flex-row-reverse' : ''}`}>
      <div class="flex-1">
        {heading && (
          <h2 class="section-heading mb-6">
            {heading}
          </h2>
        )}
        {description && (
          <p class="section-tagline mb-8">
            {typeof description === 'string' ? description : description[0]?.children?.map((child: any) => child.text).join(' ')}
          </p>
        )}
        {(bulletPoints.length > 0 || features.length > 0) && (
          <div class="space-y-4">
            {bulletPoints.map((point: string) => (
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary mt-1 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-muted leading-relaxed">{point}</span>
              </div>
            ))}
            {features.map((feature: any) => (
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-primary mt-1 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-muted leading-relaxed">{feature.text || feature}</span>
              </div>
            ))}
          </div>
        )}
      </div>
      {image && (
        <div class="flex-1 w-full">
          <img
            src={image?.asset?.url || '/images/placeholder-portrait.svg'}
            alt="Raza Dotani"
            class="media-frame aspect-[4/5]"
            loading="lazy"
          />
        </div>
      )}
    </div>
  </div>
</section>
---
interface Props {
  section: any
  services?: any[]
}

const {section, services: passedServices = []} = Astro.props
const {
  sectionTitle,
  sectionTagline,
  headerButton,
  displayMode = 'auto',
  manualServices = [],
  cardLayout = 'cards-3',
  paddingTop = 'py-20',
  paddingBottom = 'py-20',
  backgroundColor,
} = section

const services = displayMode === 'manual' ? manualServices : passedServices
---

<section
  class={`w-full ${paddingTop} ${paddingBottom}`}
  style={backgroundColor ? `background-color: ${backgroundColor}` : undefined}
>
  <div class="section-container">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
      <div class="max-w-2xl">
        {sectionTitle && (
          <h2 class="section-heading mb-4">
            {sectionTitle}
          </h2>
        )}
        {sectionTagline && (
          <p class="section-tagline">
            {sectionTagline}
          </p>
        )}
      </div>
      {headerButton?.label && (
        <a href={headerButton.url} class="link-outline shrink-0">
          {headerButton.label}
        </a>
      )}
    </div>

    {cardLayout === 'list' ? (
      <div class="space-y-4">
        {services.map((service: any) => (
          <div class="card-surface flex items-start gap-5 p-6 md:p-7">
            {service.icon && (
              <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center shrink-0">
                <span class="text-primary text-xl">{service.icon}</span>
              </div>
            )}
            <div class="flex-1 min-w-0">
              <h3 class="font-display text-xl font-semibold text-heading mb-2">{service.title}</h3>
              {(service.oneLinePromise || service.shortDescription) && (
                <p class="text-muted mb-4">{service.oneLinePromise || service.shortDescription}</p>
              )}
              {service.features && service.features.length > 0 && (
                <ul class="space-y-1.5 mb-4">
                  {service.features.slice(0, 3).map((feature: any) => (
                    <li class="text-sm text-muted flex items-start gap-2">
                      <span class="text-primary mt-0.5">•</span>
                      {feature.text || feature}
                    </li>
                  ))}
                </ul>
              )}
              {service.bestFor && (
                <p class="text-sm text-accent">Best for: {service.bestFor}</p>
              )}
            </div>
            <a
              href={service.url || `/services/${service.slug?.current}`}
              class="text-sm font-medium text-primary hover:underline shrink-0"
            >
              View Service →
            </a>
          </div>
        ))}
      </div>
    ) : (
      <div class={cardLayout === 'cards-4' ? 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6' : 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6'}>
        {services.map((service: any) => (
          <div class="card-surface p-6 md:p-7 h-full flex flex-col">
            {service.icon && (
              <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-5">
                <span class="text-primary text-xl">{service.icon}</span>
              </div>
            )}
            <h3 class="font-display text-xl font-semibold text-heading mb-2">{service.title}</h3>
            {(service.oneLinePromise || service.shortDescription) && (
              <p class="text-muted mb-4 flex-1">{service.oneLinePromise || service.shortDescription}</p>
            )}
            {service.features && service.features.length > 0 && (
              <ul class="space-y-2 mb-4">
                {service.features.slice(0, 3).map((feature: any) => (
                  <li class="text-sm text-muted flex items-start gap-2">
                    <span class="text-primary mt-0.5">•</span>
                    {feature.text || feature}
                  </li>
                ))}
              </ul>
            )}
            {service.bestFor && (
              <p class="text-sm text-accent mb-4">Best for: {service.bestFor}</p>
            )}
            <a
              href={service.url || `/services/${service.slug?.current}`}
              class="mt-auto inline-block text-sm font-medium text-primary hover:underline"
            >
              View Service →
            </a>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
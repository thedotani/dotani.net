---
interface Props {
  section: any
  portfolioItems?: any[]
}

const {section, portfolioItems: passedItems = []} = Astro.props
const {
  sectionTitle,
  sectionTagline,
  ctaButton,
  displayMode = 'auto',
  manualItems = [],
  cardLayout = 'cards-3',
  paddingTop = 'py-20',
  paddingBottom = 'py-20',
  backgroundColor,
} = section

const items = displayMode === 'manual' ? manualItems : passedItems
---

<section
  class={`w-full ${paddingTop} ${paddingBottom}`}
  style={backgroundColor ? `background-color: ${backgroundColor}` : 'background-color: color-mix(in srgb, var(--color-bg) 94%, var(--color-muted) 6%)'}
>
  <div class="section-container">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
      <div class="max-w-2xl">
        {sectionTitle && (
          <h2 class="section-heading mb-4">
            {sectionTitle}
          </h2>
        )}
        {sectionTagline && (
          <p class="section-tagline">
            {sectionTagline}
          </p>
        )}
      </div>
      {ctaButton?.label && (
        <a href={ctaButton.url} class="link-outline shrink-0">
          {ctaButton.label}
        </a>
      )}
    </div>

    <div class={cardLayout === 'cards-4' ? 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6' : 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6'}>
      {items.map((item: any) => (
        <article class="group card-surface overflow-hidden p-0 hover:translate-y-0">
          <div class="aspect-video overflow-hidden bg-border/30">
            <img
              src={item.thumbnail?.asset?.url || '/images/placeholder-portfolio.svg'}
              alt={item.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="p-6">
            <span class="section-eyebrow text-xs">
              {item.category}
            </span>
            <h3 class="font-display text-xl font-semibold text-heading mt-2 mb-2">
              {item.title}
            </h3>
            {item.shortResult && (
              <p class="text-sm text-muted mb-4 leading-relaxed">
                {item.shortResult}
              </p>
            )}
            {item.role && (
              <p class="text-sm text-accent mb-4">
                Role: {item.role}
              </p>
            )}
            <a
              href={item.url || `/portfolio/${item.slug?.current}`}
              class="inline-block text-sm font-medium text-primary hover:underline"
            >
              View Project →
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
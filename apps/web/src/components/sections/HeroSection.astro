---
interface Props {
  section: any
}

const {section} = Astro.props
const {
  eyebrow,
  heading,
  tagline,
  description,
  buttons,
  heroImage,
  layout = 'contentLeft',
  verticalAlignment = 'items-center',
  paddingTop = 'py-20',
  paddingBottom = 'py-20',
  backgroundColor,
} = section
---

<section
  class={`w-full ${paddingTop} ${paddingBottom}`}
  style={backgroundColor ? `background-color: ${backgroundColor}` : undefined}
>
  <div class="section-container">
    <div class={`flex flex-col ${layout === 'centered' ? 'text-center items-center' : 'md:flex-row'} gap-10 lg:gap-14 ${verticalAlignment}`}>
      <div class={layout === 'centered' ? 'w-full max-w-3xl' : 'flex-1'}>
        {eyebrow && (
          <p class="section-eyebrow mb-3">
            {eyebrow}
          </p>
        )}
        {heading && (
          <h1 class="section-heading-hero mb-5">
            {heading}
          </h1>
        )}
        {tagline && (
          <p class="section-tagline mb-6">
            {tagline}
          </p>
        )}
        {description && (
          <div class="text-muted leading-relaxed mb-8 max-w-2xl">
            {description[0]?.children?.map((child: any) => child.text).join(' ')}
          </div>
        )}
        {buttons && buttons.length > 0 && (
          <div class={`flex flex-wrap gap-4 ${layout === 'centered' ? 'justify-center' : ''}`}>
            {buttons.map((button: any) => (
              <a
                href={button.url}
                class={`btn btn-${button.style || 'primary'}`}
                target={button.openInNewTab ? '_blank' : undefined}
                rel={button.openInNewTab ? 'noopener noreferrer' : undefined}
              >
                {button.label}
              </a>
            ))}
          </div>
        )}
      </div>

      {heroImage && layout !== 'centered' && (
        <div class="flex-1 w-full">
          <img
            src={heroImage?.asset?.url || '/images/placeholder-hero.svg'}
            alt={heading || 'Hero image'}
            class="media-frame aspect-[4/3]"
            loading="eager"
          />
        </div>
      )}
    </div>
  </div>
</section>
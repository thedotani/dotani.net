---
interface Props {
  href: string
  label?: string
  icon?: 'arrow-up-right' | 'arrow-right' | 'external-link'
  class?: string
}

const {
  href,
  label,
  icon = 'arrow-up-right',
  class: className = '',
  ...rest
} = Astro.props

const classes = ['link-chip', className].filter(Boolean).join(' ')

const icons = {
  'arrow-up-right': '<path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M17 7l-10 10" /><path d="M17 7v10h-10" />',
  'arrow-right': '<path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12l14 0" /><path d="M12 5l7 7l-7 7" />',
  'external-link': '<path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M17 7l-10 10" /><path d="M17 7v10h-10" />',
}
---

<a href={href} class={classes} {...rest}>
  {label && <span>{label}</span>}
  <svg class="link-chip-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons[icon]} />
</a>

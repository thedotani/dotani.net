---
import styles from './Badge.module.css'

interface Props {
  variant?: 'accent' | 'success' | 'primary'
  size?: 'sm' | 'md'
  class?: string
}

const {
  variant = 'accent',
  size = 'md',
  class: className = '',
  ...rest
} = Astro.props

const classes = [
  styles.badge,
  styles[`badge--${variant}`],
  size !== 'md' && styles[`badge--${size}`],
  className,
].filter(Boolean).join(' ')
---

<span class={classes} {...rest}>
  <slot />
</span>

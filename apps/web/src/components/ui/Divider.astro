---
interface Props {
  variant?: 'gradient' | 'subtle'
  class?: string
}

const {
  variant = 'gradient',
  class: className = '',
  ...rest
} = Astro.props

const classes = ['section-divider', variant !== 'gradient' && `section-divider--${variant}`, className].filter(Boolean).join(' ')
---

<div class={classes} {...rest}></div>

---
import styles from './Card.module.css'

interface Props {
  variant?: 'elevated' | 'interactive' | 'flat'
  class?: string
  padding?: 'none' | 'sm' | 'md' | 'lg'
}

const {
  variant = 'elevated',
  class: className = '',
  padding = 'md',
  ...rest
} = Astro.props

const classes = [
  styles['card'],
  variant !== 'elevated' && styles[`card--${variant}`],
  padding !== 'md' && styles[`card--pad-${padding}`],
  className,
].filter(Boolean).join(' ')
---

<div class={classes} {...rest}>
  <slot />
</div>

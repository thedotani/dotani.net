---
import styles from './Button.module.css'

interface Props {
  variant?: 'primary' | 'secondary' | 'ghost' | 'outline' | 'white'
  size?: 'sm' | 'md' | 'lg'
  href?: string
  class?: string
  type?: 'button' | 'submit'
  disabled?: boolean
  id?: string
  target?: string
  rel?: string
  style?: string
}

const {
  variant = 'primary',
  size = 'md',
  href,
  class: className = '',
  type = 'button',
  disabled = false,
  ...rest
} = Astro.props

const classes = [
  styles['btn'],
  styles[`btn--${variant}`],
  size !== 'md' && styles[`btn--${size}`],
  className,
].filter(Boolean).join(' ')
---

{href ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} disabled={disabled} {...rest}>
    <slot />
  </button>
)}

---
interface Props {
  title: string
  description?: string
  eyebrow?: string
}

const { title, description, eyebrow } = Astro.props
---

<section class="page-banner">
  <div class="section-container">
    <div>
      {eyebrow && <p class="section-eyebrow">{eyebrow}</p>}
      <h1 class="section-heading">{title}</h1>
      {description && <p class="section-tagline">{description}</p>}
    </div>
  </div>
</section>

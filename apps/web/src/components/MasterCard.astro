---
import ServiceBadge from './ServiceBadge.astro'

interface Props {
  item: {
    title?: string
    shortResult?: string
    role?: string
    category?: string
    icon?: string
    thumbnail?: { asset?: { url?: string } }
    url?: string
    slug?: { current?: string }
  }
  showTagPill?: boolean
  showImage?: boolean
  showIcon?: boolean
  class?: string
}

const {
  item,
  showTagPill = true,
  showImage = true,
  showIcon = true,
  class: additionalClass = ''
} = Astro.props

const href = item.url || `/portfolio/${item.slug?.current}`
const hasImage = Boolean(item.thumbnail?.asset?.url) && showImage
const hasIcon = Boolean(item.icon) && showIcon
const hasCategory = Boolean(item.category) && showTagPill
---

<article class={`master-card ${additionalClass}`} data-card-spotlight>
  {hasImage ? (
    <>
      <a
        href={href}
        class="relative block aspect-[5/3] sm:aspect-video overflow-hidden master-card-image-link group"
        aria-label={`View: ${item.title}`}
        tabindex="0"
      >
        <img
          src={item.thumbnail.asset.url}
          alt={item.title || 'Featured image'}
          class="master-card-image w-full h-full object-cover"
          loading="lazy"
        />
        <div class="master-card-overlay" aria-hidden="true">
          <div class="master-card-overlay-label">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            View Project
          </div>
        </div>
        {hasCategory && (
          <div class="master-card-tag-pill-overlay" aria-hidden="true">
            <span class="tag-pill master-card-tag-pill">{item.category}</span>
          </div>
        )}
      </a>

      <div class="master-card-body flex flex-col gap-3">
        {hasIcon ? (
          <div class="master-card-header-with-badge">
            <ServiceBadge icon={item.icon} />
            <h3 class="master-card-title">
              <a href={href}>
                {item.title}
              </a>
            </h3>
          </div>
        ) : (
          <h3 class="master-card-title">
            <a href={href}>
              {item.title}
            </a>
          </h3>
        )}
        {item.shortResult && (
          <p class="master-card-description">{item.shortResult}</p>
        )}
        {item.role && (
          <p class="master-card-meta">Role: {item.role}</p>
        )}
        <a href={href} class="link-chip self-start mt-auto">
          View Project
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </>
  ) : (
    <div class="master-card-body flex flex-col gap-3">
      {hasCategory && <span class="tag-pill self-start">{item.category}</span>}

      {hasIcon ? (
        <div class="master-card-header-with-badge">
          <ServiceBadge icon={item.icon} />
          <h3 class="master-card-title">
            <a href={href}>
              {item.title}
            </a>
          </h3>
        </div>
      ) : (
        <h3 class="master-card-title-full">
          <a href={href}>
            {item.title}
          </a>
        </h3>
      )}

      {item.shortResult && (
        <p class="master-card-description flex-1">{item.shortResult}</p>
      )}

      {item.role && (
        <p class="master-card-meta">Role: {item.role}</p>
      )}

      <a href={href} class="link-chip self-start mt-auto">
        View Project
        <span aria-hidden="true">→</span>
      </a>
    </div>
  )}
</article>
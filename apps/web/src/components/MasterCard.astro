---
import chipStyles from './ui/LinkChip.module.css'
import tagStyles from './ui/Tag.module.css'
import ServiceBadge from './ServiceBadge.astro'

interface Props {
  item: {
    title?: string
    shortResult?: string
    role?: string
    category?: string
    icon?: string
    thumbnail?: { asset?: { url?: string } }
    url?: string
    slug?: { current?: string }
  }
  showTagPill?: boolean
  showImage?: boolean
  showIcon?: boolean
  class?: string
}

const {
  item,
  showTagPill = true,
  showImage = true,
  showIcon = true,
  class: additionalClass = ''
} = Astro.props

const href = item.url || `/portfolio/${item.slug?.current}`
const hasImage = Boolean(item.thumbnail?.asset?.url) && showImage
const hasIcon = Boolean(item.icon) && showIcon
const hasCategory = Boolean(item.category) && showTagPill
---

<article class={`card ${additionalClass}`}>
  {hasImage ? (
    <>
      <a
        href={href}
        class="card-img"
        aria-label={`View: ${item.title}`}
        tabindex="0"
      >
        <img
          src={item.thumbnail!.asset!.url}
          alt={item.title || 'Featured image'}
          loading="lazy"
        />
        <div class="card-overlay" aria-hidden="true">
          <div class="card-overlay-label">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            View Project
          </div>
        </div>
        {hasCategory && (
          <div class="tag-pills" aria-hidden="true">
            <span class={tagStyles['tag-pill'] + ' card-tag-pill'}>{item.category}</span>
          </div>
        )}
      </a>

<div class="card-body">
        {hasIcon ? (
          <div class="card-header-with-badge">
            <ServiceBadge icon={item.icon} />
            <h3 class="card-title">
              <a href={href}>
                {item.title}
              </a>
            </h3>
          </div>
        ) : (
          <h3 class="card-title">
            <a href={href}>
              {item.title}
            </a>
          </h3>
        )}
        {item.shortResult && (
          <p class="card-description">{item.shortResult}</p>
        )}
        {item.role && (
          <p class="card-meta">Role: {item.role}</p>
        )}
<a href={href} class={chipStyles['link-chip']}>
          View Project
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </>
  ) : (
    <div class="card-body">
      {hasCategory && <span class={tagStyles['tag-pill']}>{item.category}</span>}

      {hasIcon ? (
        <div class="card-header-with-badge">
          <ServiceBadge icon={item.icon} />
          <h3 class="card-title">
            <a href={href}>
              {item.title}
            </a>
          </h3>
        </div>
      ) : (
        <h3 class="card-title-full">
          <a href={href}>
            {item.title}
          </a>
        </h3>
      )}

      {item.shortResult && (
        <p class="card-description">{item.shortResult}</p>
      )}

      {item.role && (
        <p class="card-meta">Role: {item.role}</p>
      )}

      <a href={href} class={chipStyles['link-chip']}>
        View Project
        <span aria-hidden="true">→</span>
      </a>
    </div>
  )}
</article>

---
import Button from './ui/Button.astro'

interface Props {
  headline?: string
  supportingText?: string
  calLink?: string
  buttonLabel?: string
  centered?: boolean
}

const {
  headline = 'Prefer a call?',
  supportingText = 'Book a 30-minute intro call directly in my calendar. No agenda required.',
  calLink,
  buttonLabel = 'Book a Call',
  centered = true,
} = Astro.props

const href = calLink || (import.meta.env.PUBLIC_CALCOM_USERNAME
  ? `https://cal.com/${import.meta.env.PUBLIC_CALCOM_USERNAME}`
  : '')
---

{centered ? (
  <>
    {headline && <h2 class="section-heading">{headline}</h2>}
    {supportingText && <p class="section-tagline">{supportingText}</p>}
    {href && (
      <div>
        <Button variant="primary" href={href}>{buttonLabel}</Button>
      </div>
    )}
  </>
) : (
  <div>
    <div>
      {headline && <h2 class="section-heading">{headline}</h2>}
      {supportingText && <p class="section-tagline">{supportingText}</p>}
    </div>
    {href && (
      <Button variant="primary" href={href}>{buttonLabel}</Button>
    )}
  </div>
)}

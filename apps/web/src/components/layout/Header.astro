---
import SocialLinks from './SocialLinks.astro'
import ThemeToggle from './ThemeToggle.astro'
import { isNavActive } from '../../lib/navigation'
import type { MenuPlacement } from '../../lib/menus'

interface Props {
  menuItems: Array<{ label: string; url: string }>
  pathname: string
  socialLinks?: Array<{ platform: string; url: string }>
  cta?: { label: string; url: string }
  logo?: { asset?: { url?: string } }
  logoAlt?: string
  siteTitle?: string
  showMobileToggle?: boolean
}

const {
  menuItems,
  pathname,
  socialLinks = [],
  cta,
  logo,
  logoAlt,
  siteTitle = 'dotani.net',
  showMobileToggle = true,
} = Astro.props

const hasLogo = Boolean(logo?.asset?.url)
---

<header class="site-header" data-site-header>
  <div class="site-header-bar">
    <div class="site-header-brand">
      {showMobileToggle && (
        <button
          type="button"
          class="header-icon-btn md:hidden"
          aria-expanded="false"
          aria-controls="mobile-menu-overlay"
          data-mobile-menu-toggle
          aria-label="Open menu"
        >
          <svg class="header-menu-icon" data-menu-icon="open" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M4 7h16M4 12h16M4 17h16" />
          </svg>
          <svg class="header-menu-icon" data-menu-icon="close" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true" style="display:none">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M6 6l12 12M18 6L6 18" />
          </svg>
        </button>
      )}

      <a href="/" class="site-logo">
        {hasLogo && (
          <img
            src={logo!.asset!.url}
            alt={logoAlt || siteTitle}
            class="site-logo-image"
          />
        )}
        {!hasLogo && (
          <span class="site-logo-text">{siteTitle}</span>
        )}
      </a>
    </div>

    {menuItems.length > 0 && (
      <nav class="site-nav-desktop" aria-label="Main navigation">
        {menuItems.map((item: any) => (
          <a
            href={item.url}
            class:list={[
              'nav-link',
              { 'nav-link--active': isNavActive(pathname, item.url) },
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>
    )}

    <div class="site-header-utilities">
      {socialLinks.length > 0 && (
        <SocialLinks links={socialLinks} variant="header" />
      )}
      {cta?.label && (
        <a href={cta.url} class="btn-header-cta btn-header-cta--mobile">
          {cta.label}
        </a>
      )}
      <ThemeToggle />
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector('[data-mobile-menu-toggle]')
  const overlay = document.querySelector('[data-mobile-menu-overlay]')
  const backdrop = document.querySelector('[data-mobile-menu-backdrop]')
  const openIcon = toggle?.querySelector('[data-menu-icon="open"]')
  const closeIcon = toggle?.querySelector('[data-menu-icon="close"]')

  const setMenuOpen = (open: boolean) => {
    overlay?.classList.toggle('mobile-menu-overlay--open', open)
    overlay?.setAttribute('aria-hidden', String(!open))
    toggle?.setAttribute('aria-expanded', String(open))
    toggle?.setAttribute('aria-label', open ? 'Close menu' : 'Open menu')
    if (openIcon) openIcon.style.display = open ? 'none' : ''
    if (closeIcon) closeIcon.style.display = open ? '' : 'none'
    document.body.classList.toggle('menu-open', open)
  }

  toggle?.addEventListener('click', () => {
    const isOpen = overlay?.classList.contains('mobile-menu-overlay--open')
    setMenuOpen(!isOpen)
  })

  backdrop?.addEventListener('click', () => setMenuOpen(false))

  overlay?.querySelectorAll('[data-mobile-nav-link]').forEach((link) => {
    link.addEventListener('click', () => setMenuOpen(false))
  })

  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && overlay?.classList.contains('mobile-menu-overlay--open')) {
      setMenuOpen(false)
    }
  })
</script>
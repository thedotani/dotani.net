---
import styles from './Header.module.css'
import SocialLinks from './SocialLinks.astro'
import ThemeToggle from './ThemeToggle.astro'
import Button from '../../components/ui/Button.astro'
import { isNavActive } from '../../lib/navigation'

interface Props {
  menuItems: Array<{ label: string; url: string }>
  pathname: string
  socialLinks?: Array<{ platform: string; url: string }>
  cta?: { label: string; url: string }
  logo?: { asset?: { url?: string } }
  logoAlt?: string
  siteTitle?: string
  showMobileToggle?: boolean
}

const {
  menuItems,
  pathname,
  socialLinks = [],
  cta,
  logo,
  logoAlt,
  siteTitle = 'dotani.net',
  showMobileToggle = true,
} = Astro.props

const hasLogo = Boolean(logo?.asset?.url)
---

<header class={styles['site-header']} data-site-header>
  <div class={styles['site-header-bar']}>
    <div class={styles['site-header-brand']}>
      {showMobileToggle && (
        <button
          type="button"
          class={styles['header-icon-btn']}
          aria-expanded="false"
          aria-controls="mobile-menu-overlay"
          data-mobile-menu-toggle
          aria-label="Open menu"
        >
          <svg class={styles['header-menu-icon']} data-menu-icon="open" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M4 7h16M4 12h16M4 17h16" />
          </svg>
          <svg class={styles['header-menu-icon']} data-menu-icon="close" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true" style="display:none">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M6 6l12 12M18 6L6 18" />
          </svg>
        </button>
      )}

      <a href="/" class={styles['site-logo']}>
        {hasLogo && (
          <img
            src={logo!.asset!.url}
            alt={logoAlt || siteTitle}
            class={styles['site-logo-image']}
          />
        )}
        {!hasLogo && (
          <span class="logo-text">{siteTitle}</span>
        )}
      </a>
    </div>

    {menuItems.length > 0 && (
      <nav class={styles['site-nav-desktop']} aria-label="Main navigation">
        {menuItems.map((item: any) => (
          <a
            href={item.url}
            class:list={[
              styles['nav-link'],
              { [styles['nav-link--active']]: isNavActive(pathname, item.url) },
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>
    )}

    <div class={styles['site-header-utilities']}>
      {socialLinks.length > 0 && (
        <SocialLinks links={socialLinks} variant="header" />
      )}
      {cta?.label && (
        <Button href={cta.url}>{cta.label}</Button>
      )}
      <ThemeToggle />
    </div>
  </div>
</header>

<script defer src="/scripts/mobile-menu.js"></script>

---
import styles from './ThemeToggle.module.css'
---

<button
  type="button"
  class={styles['theme-toggle']}
  data-theme-toggle
  aria-label="Toggle color theme"
>
  <svg class={styles['theme-icon']} data-theme-icon="dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
  </svg>
  <svg class={styles['theme-icon']} data-theme-icon="light" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true" style="display:none">
    <circle cx="12" cy="12" r="4" stroke-width="1.75" />
    <path stroke-linecap="round" stroke-width="1.75" d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
  </svg>
</button>

<script defer src="/scripts/theme-toggle.js"></script>

---
import styles from './Footer.module.css'
import SocialLinks from './SocialLinks.astro'
import { resolveMenuItems, type MenuPlacement } from '../../lib/menus'

interface Props {
  footer?: {
    description?: string
    col2Heading?: string
    col3Heading?: string
    col4Heading?: string
    copyrightText?: string
  }
  brand?: {
    logos?: {
      footer?: { asset?: { url?: string } }
      main?: { asset?: { url?: string } }
    }
    logoAlt?: string
    siteTitle?: string
  }
  header?: {
    logo?: { asset?: { url?: string } }
    logoAlt?: string
    title?: string
  }
  menus?: {
    items?: Array<{
      label: string
      url: string
      showIn?: Partial<Record<MenuPlacement, boolean>>
    }>
  }
  socialLinks?: Array<{ platform: string; url: string }>
}

const FOOTER_COLUMN_PLACEMENTS: Array<{ placement: MenuPlacement; heading?: string }> = [
  { placement: 'footerCol2' },
  { placement: 'footerCol3' },
  { placement: 'footerCol4' },
]

const { footer, brand, header, menus, socialLinks = [] } = Astro.props
const footerLogo = brand?.logos?.footer || brand?.logos?.main || header?.logo
const hasLogo = Boolean(footerLogo?.asset?.url)
const siteTitle = brand?.siteTitle || header?.title || 'dotani.net'
const logoAlt = brand?.logoAlt || header?.logoAlt || siteTitle
const copyrightMenuItems = resolveMenuItems(menus?.items, undefined, 'footerCopyright')

const columnHeadings = [
  footer?.col2Heading,
  footer?.col3Heading,
  footer?.col4Heading,
]

const menuColumns = FOOTER_COLUMN_PLACEMENTS.map((column, index) => {
  const linkItems = resolveMenuItems(menus?.items, undefined, column.placement)
  const heading = columnHeadings[index]

  return {
    colNumber: index + 2,
    heading,
    linkItems,
  }
}).filter((column) => column.linkItems.length > 0)
---

<footer class={styles['site-footer']}>
  <div class={`section-container ${styles['footer-inner']}`}>
    <div class={styles['footer-main']}>
      <div class={styles['footer-brand-section']}>
        <a href="/" class={styles['footer-brand-mark']}>
          {hasLogo ? (
            <img
              src={footerLogo!.asset!.url}
              alt={logoAlt}
              class={styles['footer-brand-logo-image']}
            />
          ) : (
            <span class="logo-text">{siteTitle}</span>
          )}
        </a>
        {footer?.description && (
          <p class={styles['footer-brand-description']}>{footer.description}</p>
        )}
        {socialLinks.length > 0 && (
          <div class={styles['footer-social-inline']}>
            <SocialLinks links={socialLinks} variant="footer" />
          </div>
        )}
      </div>

      {menuColumns.length > 0 && (
        <div class={styles['footer-columns']}>
          {menuColumns.map((column) => (
            <div class={`${styles['footer-column']} ${styles[`footer-column--${column.colNumber}`]}`}>
              {column.heading && (
                <h3 class={styles['footer-heading']}>
                  <span class={styles['footer-heading-mark']} aria-hidden="true" />
                  {column.heading}
                </h3>
              )}
              <ul class={styles['footer-links']}>
                {column.linkItems.map((link) => (
                  <li>
                    <a href={link.url} class={styles['footer-link']}>
                      <span class={styles['footer-link-arrow']} aria-hidden="true">→</span>
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      )}
    </div>

    <div class={styles['footer-copyright-row']}>
      <p class={styles['footer-copyright']}>
        {footer?.copyrightText || `© ${new Date().getFullYear()} dotani.net`}
      </p>
      {copyrightMenuItems.length > 0 && (
        <nav class={styles['footer-copyright-nav']} aria-label="Footer links">
          {copyrightMenuItems.map((item) => (
            <a href={item.url} class={styles['footer-copyright-link']}>{item.label}</a>
          ))}
        </nav>
      )}
    </div>
  </div>
</footer>
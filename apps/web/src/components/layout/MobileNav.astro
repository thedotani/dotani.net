---
import styles from './MobileNav.module.css'
import SocialLinks from './SocialLinks.astro'
import { isNavActive } from '../../lib/navigation'

interface Props {
  menuItems: Array<{ label: string; url: string }>
  pathname: string
  socialLinks?: Array<{ platform: string; url: string }>
  menuFooterItems?: Array<{ label: string; url: string }>
  menuFooterText?: string
  variant?: 'toggle' | 'overlay'
}

const {
  menuItems,
  pathname,
  socialLinks = [],
  menuFooterItems = [],
  menuFooterText,
  variant = 'toggle',
} = Astro.props
---

{variant === 'overlay' && (
  <div
    id="mobile-menu-overlay"
    class={styles['mobile-menu-overlay']}
    data-mobile-menu-overlay
    aria-hidden="true"
  >
    <button type="button" class={styles['mobile-menu-backdrop']} data-mobile-menu-backdrop aria-label="Close menu"></button>
    <div class={styles['mobile-menu-drawer']} role="dialog" aria-modal="true" aria-label="Site navigation">
      <nav class={styles['mobile-menu-grid']}>
        {menuItems.map((item) => (
          <a
            href={item.url}
            class:list={[
              styles['mobile-menu-item'],
              { [styles['mobile-menu-item--active']]: isNavActive(pathname, item.url) },
            ]}
            data-mobile-nav-link
          >
            {item.label}
          </a>
        ))}
      </nav>

      {socialLinks.length > 0 && (
        <>
          <div class={styles['mobile-menu-separator']} role="presentation"></div>
          <SocialLinks links={socialLinks} variant="menu" />
        </>
      )}

      {menuFooterItems.length > 0 && (
        <nav class={styles['mobile-menu-footer']} aria-label="Mobile menu footer">
          {menuFooterItems.map((item) => (
            <a href={item.url} class={styles['mobile-menu-footer-link']} data-mobile-nav-link>
              {item.label}
            </a>
          ))}
        </nav>
      )}

      {menuFooterText && (
        <p class={styles['mobile-menu-footer']}>{menuFooterText}</p>
      )}
    </div>
  </div>
)}

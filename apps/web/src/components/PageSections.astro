---
import ContentBoxSection from './sections/ContentBoxSection.astro'
import ContentSetSection from './sections/ContentSetSection.astro'
import RichTextSection from './sections/RichTextSection.astro'

interface Section {
  _type: string
  visible?: boolean
  sectionWidth?: string
  paddingTop?: string
  paddingBottom?: string
  [key: string]: unknown
}

interface Props {
  page?: any
  sections?: Section[]
  services?: any[]
  portfolioItems?: any[]
  testimonials?: any[]
  caseStudies?: any[]
  blogPosts?: any[]
  showFallback?: boolean
}

const {
  page,
  sections = (page?.sections ?? []) as Section[],
  services = [],
  portfolioItems = [],
  testimonials = [],
  caseStudies = [],
  blogPosts = [],
  showFallback = true,
} = Astro.props

const visibleSections = sections.filter((section) => section?.visible !== false)
const hasVisibleSections = visibleSections.length > 0
const shouldShowFallback = showFallback && (!page || !hasVisibleSections)

function resolveComponent(type: string) {
  switch (type) {
    case 'contentBoxSection':
      return ContentBoxSection
    case 'contentSetSection':
      return ContentSetSection
    case 'richTextSection':
      return RichTextSection
    default:
      return null
  }
}

function sectionProps(section: any) {
  if (section._type === 'contentBoxSection') {
    return {
      section,
      services,
      portfolioItems,
      testimonials,
      caseStudies,
      blogPosts,
    }
  }
  return { section }
}

function effectiveSectionWidth(section: any, prev: any, next: any): string | undefined {
  if (section?.sectionWidth === 'half' && prev?.sectionWidth !== 'half' && next?.sectionWidth !== 'half') {
    return undefined
  }
  return section?.sectionWidth
}
---

<main class="block-sections-stack">
  {shouldShowFallback && (
    <section class="section-container">
      <p>dotani.net</p>
      <h1>
        {page?.title || 'Welcome'}
      </h1>
      <p>
        {page?.excerpt ||
          'Content is being prepared. Add a page and site settings in Sanity Studio to populate this site.'}
      </p>
      {import.meta.env.DEV && (
        <a
          href="http://localhost:3333"
          class=""
        >
          Open Sanity Studio
        </a>
      )}
    </section>
  )}

  {visibleSections.map((section, index) => {
    const prev = visibleSections[index - 1]
    const next = visibleSections[index + 1]
    const isHalfStart = section?.sectionWidth === 'half' && next?.sectionWidth === 'half'
    const isHalfEnd = prev?.sectionWidth === 'half' && section?.sectionWidth === 'half'

    if (isHalfStart) {
      const nextSection = next
      const Component = resolveComponent(section._type)
      const NextComponent = resolveComponent(nextSection._type)
      if (!Component || !NextComponent) return null

      return (
        <div>
          <div>
            <Component {...sectionProps({ ...section, sectionWidth: undefined })} />
          </div>
          <div>
            <NextComponent {...sectionProps({ ...nextSection, sectionWidth: undefined })} />
          </div>
        </div>
      )
    }

    if (isHalfEnd) return null

    const Component = resolveComponent(section._type)
    if (!Component) return null

    const overrideWidth = effectiveSectionWidth(section, prev, next)

    return (
      <Component {...sectionProps(overrideWidth !== section.sectionWidth ? { ...section, sectionWidth: overrideWidth } : section)} />
    )
  })}
</main>
---
import Button from './ui/Button.astro'
import inputStyles from './ui/Input.module.css'

interface Props {
  headline?: string
  supportingText?: string
  submitButtonText?: string
}

const {
  headline = 'Send a message',
  supportingText = "Tell me about the project, the problem, or the idea. I'll get back to you within 48 hours.",
  submitButtonText = 'Send Message',
} = Astro.props
---

{headline && (
    <h2 class="section-heading">
      {headline}
    </h2>
  )}
  {supportingText && (
    <p class="section-tagline">
      {supportingText}
    </p>
  )}

  <div
    id="contact-status"
    role="alert"
    aria-live="polite"
  ></div>

  <form
    class="card-surface"
    id="contact-form"
    action="/api/contact"
    method="POST"
  >
    <div class="cf-turnstile" data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY}></div>

    <div>
      <label for="name">Name</label>
      <input type="text" id="name" name="name" required autocomplete="name" maxlength={100} class={inputStyles['input']} placeholder="Your name" />
    </div>

    <div>
      <label for="email">Email</label>
      <input type="email" id="email" name="email" required autocomplete="email" class={inputStyles['input']} placeholder="your@email.com" />
    </div>

    <div>
      <label for="message">Message</label>
      <textarea id="message" name="message" rows={5} required maxlength={5000} class={inputStyles['input']} placeholder="How can I help you?"></textarea>
    </div>

    <Button type="submit" id="contact-submit" variant="primary">{submitButtonText}</Button>
  </form>

<script defer src="/scripts/contact-form.js"></script>

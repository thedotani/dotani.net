---
interface Props {
  title?: string
  tagline?: string
  action?: { label: string; url: string }
  centered?: boolean
  headingTag?: 'h1' | 'h2' | 'h3'
  headingClass?: string
}

const {
  title,
  tagline,
  action,
  centered = false,
  headingTag = 'h2',
  headingClass = 'section-heading section-heading-inline',
} = Astro.props

const HeadingTag = headingTag
---

{(title || tagline || action?.label) && (
  <div class:list={['section-header-bar', { 'section-header-bar-centered': centered }]}>
    <div class="sec-title">
      {title && <HeadingTag class={headingClass}>{title}</HeadingTag>}
      {tagline && <p class="section-tagline section-tagline-inline">{tagline}</p>}
    </div>
    {action?.label && (
      <a href={action.url} class="link-chip">
        {action.label}
        <span aria-hidden="true">→</span>
      </a>
    )}
  </div>
)}
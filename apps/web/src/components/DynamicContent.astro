---
import ServiceBadge from './ServiceBadge.astro'
import { portfolioAccent } from '../lib/sectionStyle'

interface Props {
  type?: string
  services?: any[]
  portfolioItems?: any[]
  testimonials?: any[]
  caseStudies?: any[]
  blogPosts?: any[]
  limit?: number
  centered?: boolean
}

const {
  type,
  services = [],
  portfolioItems = [],
  testimonials = [],
  caseStudies = [],
  blogPosts = [],
  limit = 3,
  centered = false,
} = Astro.props

function sliceItems<T>(items: T[]) {
  return limit > 0 ? items.slice(0, limit) : items
}
---

{type === 'service' && (
  <div data-motion-stagger class="listing-grid">
    {sliceItems(services).map((service: any) => (
      <div class="listing-card" data-card-spotlight>
        <ServiceBadge icon={service.icon} />
        <h3 class="font-display text-xl font-semibold text-heading">{service.title}</h3>
        {service.shortDescription && (
          <p class="text-muted flex-1 leading-relaxed">{service.shortDescription}</p>
        )}
        {service.features && service.features.length > 0 && (
          <ul class="space-y-2">
            {service.features.slice(0, 3).map((feature: any) => (
              <li class="text-sm text-muted flex items-start gap-2">
                <span class="text-primary mt-0.5">•</span>
                {feature.text || feature}
              </li>
            ))}
          </ul>
        )}
        {service.bestFor && <p class="text-sm text-accent">Best for: {service.bestFor}</p>}
        <a href={`/services/${service.slug?.current}`} class="link-chip mt-auto">
          View Service
          <span aria-hidden="true">→</span>
        </a>
      </div>
    ))}
  </div>
)}

{type === 'portfolio' && (
  <div data-motion-stagger class="listing-grid">
    {sliceItems(portfolioItems).map((item: any, index: number) => {
      const href = `/portfolio/${item.slug?.current}`
      const thumbnailUrl = item.thumbnail?.asset?.url
      const [from, to] = portfolioAccent(item.title, index)
      return (
        <article class="master-card group" data-card-spotlight>
          <a
            href={href}
            class="master-card-image-link relative block aspect-[5/3] sm:aspect-video overflow-hidden portfolio-img-link"
            aria-label={`View project: ${item.title}`}
          >
            {thumbnailUrl ? (
              <img
                src={thumbnailUrl}
                alt={item.title}
                class="portfolio-card-image w-full h-full object-cover"
                loading="lazy"
              />
            ) : (
              <div
                class="portfolio-placeholder w-full h-full"
                style={`--placeholder-from: ${from}; --placeholder-to: ${to}`}
              >
                <span class="portfolio-placeholder__label">{item.category || 'Project'}</span>
                <strong class="portfolio-placeholder__title">{item.title}</strong>
              </div>
            )}
            <div class="portfolio-card-overlay" aria-hidden="true">
              <div class="portfolio-card-overlay-label">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                View Project
              </div>
            </div>
            {item.category && (
              <div class="absolute top-3 left-3 z-10">
                <span class="tag-pill">{item.category}</span>
              </div>
            )}
          </a>
          <div class="master-card-body flex flex-col gap-3 flex-1">
            <h3 class="master-card-title">
              <a href={href}>{item.title}</a>
            </h3>
            {item.shortResult && (
              <p class="master-card-description">{item.shortResult}</p>
            )}
            <a href={href} class="link-chip mt-auto self-start">
              View Project
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </article>
      )
    })}
  </div>
)}

{type === 'testimonial' && (
  <div
    data-motion-stagger
    class:list={[
      'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6',
      centered && 'max-w-6xl mx-auto',
    ]}
  >
    {sliceItems(testimonials).map((item: any) => (
      <div class="card-surface testimonial-card flex flex-col gap-4 p-5 sm:p-6 md:p-7" data-card-spotlight>
        {item.quote && <p class="text-muted leading-relaxed">&ldquo;{item.quote}&rdquo;</p>}
        <div class="flex items-center gap-3 mt-auto">
          {item.authorAvatar?.asset?.url ? (
            <div class="relative">
              <img
                src={item.authorAvatar.asset.url}
                alt={item.authorName}
                class="w-11 h-11 rounded-full object-cover ring-2 ring-primary/20 shrink-0"
              />
              <div class="absolute inset-0 rounded-full ring-2 ring-primary/10 scale-110 opacity-0 transition-opacity duration-300"></div>
            </div>
          ) : (
            <div class="w-11 h-11 rounded-full bg-gradient-to-br from-primary/20 to-purple-500/20 flex items-center justify-center ring-2 ring-primary/20 shrink-0">
              <span class="text-primary font-bold text-sm">{item.authorName?.charAt(0)}</span>
            </div>
          )}
          <div class="min-w-0">
            <p class="font-display font-semibold text-heading truncate">{item.authorName}</p>
            {item.authorRole && <p class="text-sm text-muted">{item.authorRole}</p>}
          </div>
        </div>
        {item.rating && (
          <div class="flex gap-0.5" aria-label={`${item.rating} out of 5 stars`}>
            {Array.from({ length: 5 }).map((_, i) => (
              <span class:list={['text-base', i < item.rating ? 'star-filled' : 'star-empty']} aria-hidden="true">★</span>
            ))}
          </div>
        )}
      </div>
    ))}
  </div>
)}

{type === 'caseStudy' && (
  <div data-motion-stagger class="listing-grid">
    {sliceItems(caseStudies).map((item: any) => {
      const href = `/case-studies/${item.slug?.current}`
      return (
        <article class="listing-card" data-card-spotlight>
          {item.heroImage?.asset?.url && (
            <div class="relative overflow-hidden rounded-xl -mx-[var(--space-card-inner)] -mt-[var(--space-card-inner)] mb-0">
              <img src={item.heroImage.asset.url} alt={item.title} class="w-full aspect-video object-cover transition-transform duration-600" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-card/60 to-transparent"></div>
            </div>
          )}
          <h3 class="font-display text-xl font-semibold text-heading">{item.title}</h3>
          {(item.summary || item.client) && (
            <p class="text-muted flex-1">{item.summary || `${item.client}${item.industry ? ` · ${item.industry}` : ''}`}</p>
          )}
          <a href={href} class="link-chip mt-auto">Read Case Study <span aria-hidden="true">→</span></a>
        </article>
      )
    })}
  </div>
)}

{type === 'blogPost' && (
  <div data-motion-stagger class="listing-grid md:grid-cols-2">
    {sliceItems(blogPosts).map((item: any) => (
      <article class="listing-card" data-card-spotlight>
        <div class="flex items-center gap-2 mb-1">
          <div class="h-1.5 w-1.5 rounded-full bg-primary"></div>
          {item.publishedAt && (
            <p class="text-xs text-muted uppercase tracking-wider">
              {new Date(item.publishedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
            </p>
          )}
        </div>
        <h3 class="font-display text-xl font-semibold text-heading">{item.title}</h3>
        {item.excerpt && <p class="text-muted flex-1 leading-relaxed">{item.excerpt}</p>}
        {item.tags && item.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mt-auto">
            {item.tags.slice(0, 3).map((tag: string) => (
              <span class="tag-pill">{tag}</span>
            ))}
          </div>
        )}
      </article>
    ))}
  </div>
)}
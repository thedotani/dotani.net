---
import chipStyles from './ui/LinkChip.module.css'
import tagStyles from './ui/Tag.module.css'
import ServiceBadge from './ServiceBadge.astro'
import { portfolioAccent } from '../lib/sectionStyle'

interface Props {
  type?: string
  services?: any[]
  portfolioItems?: any[]
  testimonials?: any[]
  caseStudies?: any[]
  blogPosts?: any[]
  limit?: number
  centered?: boolean
}

const {
  type,
  services = [],
  portfolioItems = [],
  testimonials = [],
  caseStudies = [],
  blogPosts = [],
  limit = 3,
  centered = false,
} = Astro.props

function sliceItems<T>(items: T[]) {
  return limit > 0 ? items.slice(0, limit) : items
}
---

{type === 'service' && (
  <div class="listing-grid">
    {sliceItems(services).map((service: any) => (
      <div class="listing-card">
        <ServiceBadge icon={service.icon} />
        <h3>{service.title}</h3>
        {service.shortDescription && (
          <p>{service.shortDescription}</p>
        )}
        {service.features && service.features.length > 0 && (
          <ul>
            {service.features.slice(0, 3).map((feature: any) => (
              <li>
                {feature.text || feature}
              </li>
            ))}
          </ul>
        )}
        {service.bestFor && <p>Best for: {service.bestFor}</p>}
        <a href={`/services/${service.slug?.current}`} class={chipStyles['link-chip']}>
          View Service
          <span aria-hidden="true">→</span>
        </a>
      </div>
    ))}
  </div>
)}

{type === 'portfolio' && (
  <div class="listing-grid">
    {sliceItems(portfolioItems).map((item: any, index: number) => {
      const href = `/portfolio/${item.slug?.current}`
      const thumbnailUrl = item.thumbnail?.asset?.url
      const [from, to] = portfolioAccent(item.title, index)
      return (
        <article class="card group">
          <a
            href={href}
            class="card-img portfolio-img"
            aria-label={`View project: ${item.title}`}
          >
            {thumbnailUrl ? (
                <img
                  src={thumbnailUrl}
                  alt={item.title}
                  loading="lazy"
                />
            ) : (
              <div
                class="portfolio-placeholder"
                style={`--placeholder-from: ${from}; --placeholder-to: ${to}`}
              >
                <span class="portfolio-placeholder__label">{item.category || 'Project'}</span>
                <strong class="portfolio-placeholder__title">{item.title}</strong>
              </div>
            )}
            <div class="portfolio-card-overlay" aria-hidden="true">
              <div class="portfolio-card-overlay-label">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                View Project
              </div>
            </div>
            {item.category && (
              <div class="tag-pills">
                <span class={tagStyles['tag-pill']}>{item.category}</span>
              </div>
            )}
          </a>
          <div class="card-body">
              <h3 class="card-title">
              <a href={href}>{item.title}</a>
            </h3>
            {item.shortResult && (
              <p class="card-description">{item.shortResult}</p>
            )}
            <a href={href} class={chipStyles['link-chip']}>
              View Project
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </article>
      )
    })}
  </div>
)}

{type === 'testimonial' && (
  <div
    class:list={[
      'grid',
      centered && '',
    ]}
  >
    {sliceItems(testimonials).map((item: any) => (
      <div class="card-surface testimonial-card">
        {item.quote && <p>&ldquo;{item.quote}&rdquo;</p>}
        <div>
          {item.authorAvatar?.asset?.url ? (
            <div>
                <img
                  src={item.authorAvatar.asset.url}
                  alt={item.authorName}
                />
            </div>
          ) : (
            <div>
              <span>{item.authorName?.charAt(0)}</span>
            </div>
          )}
          <div>
            <p>{item.authorName}</p>
            {item.authorRole && <p>{item.authorRole}</p>}
          </div>
        </div>
        {item.rating && (
          <div aria-label={`${item.rating} out of 5 stars`}>
            {Array.from({ length: 5 }).map((_, i) => (
              <span class:list={[i < item.rating ? 'star-filled' : 'star-empty']} aria-hidden="true">★</span>
            ))}
          </div>
        )}
      </div>
    ))}
  </div>
)}

{type === 'caseStudy' && (
  <div class="listing-grid">
    {sliceItems(caseStudies).map((item: any) => {
      const href = `/case-studies/${item.slug?.current}`
      return (
        <article class="listing-card">
          {item.heroImage?.asset?.url && (
            <div>
              <img src={item.heroImage.asset.url} alt={item.title} loading="lazy" />
              <div></div>
            </div>
          )}
<h3>{item.title}</h3>
          {(item.summary || item.client) && (
            <p>{item.summary || `${item.client}${item.industry ? ` · ${item.industry}` : ''}`}</p>
          )}
          <a href={href} class={chipStyles['link-chip']}>Read Case Study <span aria-hidden="true">→</span></a>
        </article>
      )
    })}
  </div>
)}

{type === 'blogPost' && (
  <div class="listing-grid">
    {sliceItems(blogPosts).map((item: any) => (
      <article class="listing-card">
        <div>

          {item.publishedAt && (
<p>
              {new Date(item.publishedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
            </p>
          )}
        </div>
        <h3>{item.title}</h3>
        {item.excerpt && <p>{item.excerpt}</p>}
        {item.tags && item.tags.length > 0 && (
          <div>
            {item.tags.slice(0, 3).map((tag: string) => (
              <span class={tagStyles['tag-pill']}>{tag}</span>
            ))}
          </div>
        )}
      </article>
    ))}
  </div>
)}

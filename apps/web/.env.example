# Sanity (public — safe for client-side)
PUBLIC_SANITY_PROJECT_ID=tmw5kvr6
PUBLIC_SANITY_DATASET=production

# Turnstile (Cloudflare) — site key is public; secret is server-only
PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# Contact form (server-only)
RESEND_API_KEY=your_resend_api_key_here
CONTACT_TO_EMAIL=online@dotani.net

# Cal.com booking link fallback
PUBLIC_CALCOM_USERNAME=dotani
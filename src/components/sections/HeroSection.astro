---
interface Props {
  section: any
}

const {section} = Astro.props
const {
  eyebrow,
  heading,
  tagline,
  description,
  buttons,
  heroImage,
  layout = 'contentLeft',
  verticalAlignment = 'items-center',
  paddingTop = 'py-16',
  paddingBottom = 'py-16',
  backgroundColor,
  backgroundType = 'solid',
} = section
---

<section
  class={`w-full ${paddingTop} ${paddingBottom}`}
  style={backgroundColor ? `background-color: ${backgroundColor}` : undefined}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class={`flex flex-col ${layout === 'centered' ? 'text-center' : 'md:flex-row'} gap-8 ${verticalAlignment}`}>
      <!-- Content -->
      <div class={layout === 'centered' ? 'w-full' : 'flex-1'}>
        {eyebrow && (
          <p class="text-sm font-medium text-primary uppercase tracking-wider mb-2">
            {eyebrow}
          </p>
        )}
        {heading && (
          <h1 class="text-4xl md:text-5xl font-bold text-heading mb-4">
            {heading}
          </h1>
        )}
        {tagline && (
          <p class="text-xl text-muted mb-6">
            {tagline}
          </p>
        )}
        {description && (
          <div class="prose prose-lg max-w-none mb-8">
            {description[0]?.children?.map((child: any) => child.text).join(' ')}
          </div>
        )}
        {buttons && buttons.length > 0 && (
          <div class="flex flex-wrap gap-4">
            {buttons.map((button: any) => (
              <a
                href={button.url}
                class={`btn btn-${button.style || 'primary'}`}
                target={button.openInNewTab ? '_blank' : undefined}
                rel={button.openInNewTab ? 'noopener noreferrer' : undefined}
              >
                {button.label}
              </a>
            ))}
          </div>
        )}
      </div>

      <!-- Image -->
      {heroImage && layout !== 'centered' && (
        <div class="flex-1">
          <img
            src={heroImage?.asset?.url || '/placeholder.png'}
            alt={heading || 'Hero image'}
            class="w-full h-auto rounded-lg shadow-lg"
          />
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .text-primary { color: var(--primary-color, #3b82f6); }
  .text-heading { color: var(--heading-color, #1f2937); }
  .text-muted { color: var(--muted-color, #6b7280); }
  .btn {
    @apply px-6 py-3 rounded-lg font-medium transition-colors;
  }
  .btn-primary {
    @apply bg-primary text-white hover:bg-primary/90;
  }
  .btn-secondary {
    @apply bg-secondary text-white hover:bg-secondary/90;
  }
  .btn-ghost {
    @apply bg-transparent text-primary hover:bg-primary/10;
  }
  .btn-outline {
    @apply border border-primary text-primary hover:bg-primary/10;
  }
</style>
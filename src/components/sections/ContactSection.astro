---
interface Props {
  section: any
}

const {section} = Astro.props
const {
  headline,
  supportingText,
  formFields = [],
  submitButtonText = 'Send Message',
  successMessage = 'Thank you! Your message has been sent.',
  paddingTop = 'py-16',
  paddingBottom = 'py-16',
  backgroundColor,
} = section
---

<section
  class={`w-full ${paddingTop} ${paddingBottom}`}
  style={backgroundColor ? `background-color: ${backgroundColor}` : undefined}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mx-auto">
      {headline && (
        <h2 class="text-3xl md:text-4xl font-bold text-heading mb-4 text-center">
          {headline}
        </h2>
      )}
      {supportingText && (
        <p class="text-lg text-muted mb-8 text-center">
          {supportingText}
        </p>
      )}

      <form class="space-y-6" id="contact-form" action="/api/contact" method="POST">
        <div class="cf-turnstile" data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY}></div>

        <div>
          <label for="name" class="block text-sm font-medium text-heading mb-2">
            Name
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-3 rounded-lg border border-border focus:ring-2 focus:ring-primary focus:border-transparent outline-none"
            placeholder="Your name"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-heading mb-2">
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-3 rounded-lg border border-border focus:ring-2 focus:ring-primary focus:border-transparent outline-none"
            placeholder="your@email.com"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-heading mb-2">
            Message
          </label>
          <textarea
            id="message"
            name="message"
            rows={5}
            required
            class="w-full px-4 py-3 rounded-lg border border-border focus:ring-2 focus:ring-primary focus:border-transparent outline-none resize-none"
            placeholder="How can I help you?"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full px-6 py-3 bg-primary text-white rounded-lg font-medium hover:bg-primary/90 transition-colors"
        >
          {submitButtonText}
        </button>
      </form>
    </div>
  </div>
</section>

<style>
  .text-heading { color: var(--heading-color, #1f2937); }
  .text-muted { color: var(--muted-color, #6b7280); }
  .border-border { border-color: var(--border-color, #e5e7eb); }
</style>
---
interface Props {
  section: any
}

const {section} = Astro.props
const {
  headline,
  supportingText,
  calLink,
  buttonLabel = 'Book a Call',
  layout = 'centered',
  paddingTop = 'py-16',
  paddingBottom = 'py-16',
  backgroundColor,
} = section
---

<section
  class={`w-full ${paddingTop} ${paddingBottom}`}
  style={backgroundColor ? `background-color: ${backgroundColor}` : undefined}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {layout === 'centered' ? (
      <div class="text-center max-w-2xl mx-auto">
        {headline && (
          <h2 class="text-3xl md:text-4xl font-bold text-heading mb-4">
            {headline}
          </h2>
        )}
        {supportingText && (
          <p class="text-lg text-muted mb-8">
            {supportingText}
          </p>
        )}
        {(calLink || import.meta.env.PUBLIC_CALCOM_USERNAME) && (
          <a
            href={calLink || `https://cal.com/${import.meta.env.PUBLIC_CALCOM_USERNAME}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-8 py-4 bg-primary text-white rounded-lg font-medium hover:bg-primary/90 transition-colors"
          >
            {buttonLabel}
          </a>
        )}
      </div>
    ) : (
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8">
        <div class="flex-1">
          {headline && (
            <h2 class="text-3xl md:text-4xl font-bold text-heading mb-4">
              {headline}
            </h2>
          )}
          {supportingText && (
            <p class="text-lg text-muted">
              {supportingText}
            </p>
          )}
        </div>
        {(calLink || import.meta.env.PUBLIC_CALCOM_USERNAME) && (
          <a
            href={calLink || `https://cal.com/${import.meta.env.PUBLIC_CALCOM_USERNAME}`}
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-4 bg-primary text-white rounded-lg font-medium hover:bg-primary/90 transition-colors"
          >
            {buttonLabel}
          </a>
        )}
      </div>
    )}
  </div>
</section>

<style>
  .text-heading { color: var(--heading-color, #1f2937); }
  .text-muted { color: var(--muted-color, #6b7280); }
</style>
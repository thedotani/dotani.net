---
interface Props {
  section: any
  portfolioItems?: any[]
}

const {section, portfolioItems: passedItems = []} = Astro.props
const {
  sectionTitle,
  sectionTagline,
  ctaButton,
  displayMode = 'auto',
  manualItems = [],
  cardLayout = 'cards-3',
  paddingTop = 'py-16',
  paddingBottom = 'py-16',
  backgroundColor,
} = section

// Use manual items or passed portfolio items (from auto-fetch)
const items = displayMode === 'manual' ? manualItems : passedItems
---

<section
  class={`w-full ${paddingTop} ${paddingBottom}`}
  style={backgroundColor ? `background-color: ${backgroundColor}` : undefined}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-12">
      <div>
        {sectionTitle && (
          <h2 class="text-3xl md:text-4xl font-bold text-heading mb-4">
            {sectionTitle}
          </h2>
        )}
        {sectionTagline && (
          <p class="text-lg text-muted">
            {sectionTagline}
          </p>
        )}
      </div>
      {ctaButton?.label && (
        <a
          href={ctaButton.url}
          class="mt-4 md:mt-0 px-6 py-2 border border-primary text-primary rounded-lg hover:bg-primary/10 transition-colors"
        >
          {ctaButton.label}
        </a>
      )}
    </div>

    <div class={cardLayout === 'cards-4' ? 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6' : 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6'}>
      {items.map((item: any) => (
        <article class="group bg-card border border-border rounded-xl overflow-hidden hover:shadow-lg transition-shadow">
          {item.thumbnail && (
            <div class="aspect-video overflow-hidden">
              <img
                src={item.thumbnail?.asset?.url || '/placeholder.png'}
                alt={item.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform"
              />
            </div>
          )}
          <div class="p-6">
            <span class="text-xs font-semibold text-primary uppercase tracking-wider">
              {item.category}
            </span>
            <h3 class="text-xl font-semibold text-heading mt-2 mb-2">
              {item.title}
            </h3>
            {item.shortResult && (
              <p class="text-sm text-muted mb-4">
                {item.shortResult}
              </p>
            )}
            {item.role && (
              <p class="text-sm text-accent">
                Role: {item.role}
              </p>
            )}
            {item.url && (
              <a
                href={item.url}
                class="mt-4 inline-block text-sm font-medium text-primary hover:underline"
              >
                View Project →
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .text-heading { color: var(--heading-color, #1f2937); }
  .text-muted { color: var(--muted-color, #6b7280); }
  .text-primary { color: var(--primary-color, #3b82f6); }
  .text-accent { color: var(--accent-color, #f59e0b); }
  .bg-card { background-color: var(--card-bg, #ffffff); }
  .border-border { border-color: var(--border-color, #e5e7eb); }
</style>